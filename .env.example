# ── 에테르나 크로니클 — 환경변수 템플릿 ─────────────────────
# 이 파일을 .env로 복사한 뒤 실제 값을 채워 사용하세요.
# cp .env.example .env

# ── PostgreSQL ──
POSTGRES_DB=aeterna
POSTGRES_USER=aeterna
POSTGRES_PASSWORD=changeme

# ── 서버 ──
PORT=3000
DATABASE_URL=postgresql://aeterna:changeme@localhost:5432/aeterna
REDIS_URL=redis://localhost:6379
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:80
NODE_ENV=development

# ── 클라이언트 (VITE_ 접두사 필수) ──
VITE_SERVER_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000
VITE_API_BASE=http://localhost:3000/api

# ── P7-15: Sentry/Datadog APM ──
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE=0.2
DATADOG_API_KEY=
DATADOG_APP_KEY=
DATADOG_SITE=datadoghq.com
DD_SERVICE=aeterna-server
DD_ENV=production

# ── P7-16: 로깅 파이프라인 ──
LOKI_URL=
LOKI_TENANT=aeterna
LOKI_BATCH_SIZE=100
LOKI_FLUSH_MS=5000

# ── P7-17: CDN ──
VITE_CDN_BASE_URL=
VITE_CDN_VERSION=v1
VITE_CDN_ENABLED=false
CDN_BUCKET=aeterna-assets
CDN_DISTRIBUTION_ID=

# ── P7-18: DB 백업 ──
BACKUP_S3_BUCKET=aeterna-backups
BACKUP_S3_PREFIX=pg-backups
BACKUP_LOCAL_DIR=/tmp/aeterna-backups
BACKUP_RETENTION=7
BACKUP_WEBHOOK=

# ── 인증 ──
JWT_SECRET=changeme-jwt-secret
JWT_REFRESH_SECRET=changeme-jwt-refresh-secret

# ── 로깅 ──
LOG_LEVEL=info
LOG_DIR=./logs

# ── APM 임계값 ──
APM_CHECK_INTERVAL=30000
APM_HTTP_RESPONSE_THRESHOLD=500
APM_MEMORY_THRESHOLD_MB=512
APM_SOCKET_LATENCY_THRESHOLD=100

# ── 운영 알림 ──
ALERT_WEBHOOK_URL=
DISCORD_OPS_WEBHOOK_URL=
DISCORD_BOT_AVATAR=
SLACK_OPS_WEBHOOK_URL=
OPS_ALERT_ENABLED=false
OPS_CCU_DROP_THRESHOLD=0.3
OPS_DISK_USAGE_THRESHOLD=90
OPS_ERROR_RATE_THRESHOLD=0.05
OPS_P95_LATENCY_THRESHOLD=500
PROMETHEUS_URL=http://localhost:9090

# ── PvP ──
PVP_SEASON=1

# ── 채팅 ──
CHAT_ADMIN_KEY=

# ── 베타 ──
BETA_MAX_USERS=10000

# ── P12: SNS 공유 ──
SHARE_BASE_URL=https://aeterna.game/s

# ── P10: ClickHouse 분석 ──
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_PROTOCOL=http
CLICKHOUSE_DB=aeterna_analytics
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ── P10: Grafana 대시보드 ──
GRAFANA_URL=http://localhost:3000
GRAFANA_API_KEY=
GRAFANA_ORG_ID=1

# ── 벤치마크 ──
BENCHMARK_URL=http://localhost:3000
BENCHMARK_TOKEN=
BENCHMARK_ROUNDS=100

# ── P6-02: 결제 (Stripe) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_CRYSTAL_100=
STRIPE_PRICE_CRYSTAL_500=
STRIPE_PRICE_CRYSTAL_1100=
STRIPE_PRICE_CRYSTAL_2400=
STRIPE_PRICE_CRYSTAL_5500=
STRIPE_PRICE_CRYSTAL_12000=
STRIPE_PRICE_SEASON_PASS=
