{
  "name": "aeterna-chronicle-server",
  "version": "1.0.0",
  "description": "Game server for Aeterna Chronicle Phase 1",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate": "prisma migrate deploy"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@prisma/client": "^5.10.0",
    "fastify": "^4.26.1",
    "redis": "^4.6.13",
    "socket.io": "^4.7.4",
    "protobufjs": "^7.2.6"
  },
  "devDependencies": {
    "@types/node": "^20.11.19",
    "typescript": "^5.3.3",
    "ts-node-dev": "^2.0.0",
    "prisma": "^5.10.0"
  }
}
