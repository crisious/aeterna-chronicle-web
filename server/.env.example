# ─── Auth ─────────────────────────────────────────────────────
JWT_SECRET="your-jwt-secret-here"
JWT_REFRESH_SECRET="your-jwt-refresh-secret-here"

# ─── Server ───────────────────────────────────────────────────
NODE_ENV="development"
PORT=3000
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"
HOSTNAME="localhost"

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/aeterna_chronicle"
REDIS_URL="redis://localhost:6379"

# ─── Stripe (P9-10/11) ───────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Price IDs (크리스탈 패키지)
STRIPE_PRICE_CRYSTAL_100="price_..."
STRIPE_PRICE_CRYSTAL_500="price_..."
STRIPE_PRICE_CRYSTAL_1100="price_..."
STRIPE_PRICE_CRYSTAL_2400="price_..."
STRIPE_PRICE_CRYSTAL_5500="price_..."
STRIPE_PRICE_CRYSTAL_12000="price_..."

# Stripe Price ID (시즌패스 프리미엄 구독)
STRIPE_PRICE_SEASON_PASS="price_..."

# ─── Monitoring (Sentry) ─────────────────────────────────────
SENTRY_DSN="https://xxx@sentry.io/xxx"
SENTRY_TRACES_SAMPLE="0.1"

# ─── Monitoring (Datadog) ────────────────────────────────────
DATADOG_API_KEY=""
DATADOG_APP_KEY=""
DATADOG_SITE="datadoghq.com"
DD_SERVICE="aeterna-chronicle"

# ─── Logging (Loki) ──────────────────────────────────────────
LOKI_URL="http://localhost:3100"
LOKI_TENANT="aeterna"
LOKI_BATCH_SIZE="1000"
LOKI_FLUSH_MS="5000"
LOG_DIR="./logs"
LOG_LEVEL="info"

# ─── APM ─────────────────────────────────────────────────────
APM_CHECK_INTERVAL="30000"
APM_HTTP_RESPONSE_THRESHOLD="1000"
APM_MEMORY_THRESHOLD_MB="512"
APM_SOCKET_LATENCY_THRESHOLD="200"

# ─── Ops Alerts ──────────────────────────────────────────────
OPS_ALERT_ENABLED="false"
OPS_CCU_DROP_THRESHOLD="0.3"
OPS_DISK_USAGE_THRESHOLD="0.9"
OPS_ERROR_RATE_THRESHOLD="0.05"
OPS_P95_LATENCY_THRESHOLD="2000"
ALERT_WEBHOOK_URL=""
DISCORD_OPS_WEBHOOK_URL=""
SLACK_OPS_WEBHOOK_URL=""
PROMETHEUS_URL="http://localhost:9090"

# ─── Game Config ─────────────────────────────────────────────
BETA_MAX_USERS="10000"
CHAT_ADMIN_KEY=""
PVP_SEASON="1"

# ─── Feature Flags ───────────────────────────────────────────
FEATURE_ENDLESS_DUNGEON="true"
FEATURE_WORLD_BOSS="true"
FEATURE_TRANSCENDENCE="true"
