generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(uuid())
  username    String   @unique
  email       String   @unique
  password    String
  level       Int      @default(1)
  exp         Int      @default(0)
  classType   String   @default("memory_weaver") @map("class_type")
  gold        Int      @default(1000)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  characters  Character[]

  @@map("users")
}

model Character {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  name        String
  classType   String   @map("class_type")
  level       Int      @default(1)
  hp          Int      @default(415)
  mp          Int      @default(208)
  attack      Int      @default(45)
  defense     Int      @default(30)
  speed       Int      @default(25)
  gold        Int      @default(1000)
  mapId       String   @default("argentium") @map("map_id")
  posX        Float    @default(640) @map("pos_x")
  posY        Float    @default(360) @map("pos_y")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user        User     @relation(fields: [userId], references: [id])
  inventory   InventoryItem[]
  quests      QuestProgress[]

  @@map("characters")
}

model InventoryItem {
  id           String   @id @default(uuid())
  characterId  String   @map("character_id")
  itemId       String   @map("item_id")
  quantity     Int      @default(1)
  slotIndex    Int      @map("slot_index")
  rarity       String   @default("common")
  enhanceLevel Int      @default(0) @map("enhance_level")
  createdAt    DateTime @default(now()) @map("created_at")

  character    Character @relation(fields: [characterId], references: [id])

  @@map("inventory_items")
}

model QuestProgress {
  id              String   @id @default(uuid())
  characterId     String   @map("character_id")
  questId         String   @map("quest_id")
  status          String   @default("active")
  progressCurrent Int      @default(0) @map("progress_current")
  progressTarget  Int      @map("progress_target")
  completedAt     DateTime? @map("completed_at")
  createdAt       DateTime @default(now()) @map("created_at")

  character       Character @relation(fields: [characterId], references: [id])

  @@map("quest_progress")
}

model TelemetryDialogueChoiceEvent {
  eventId        String   @id @map("event_id")
  eventTs        DateTime @map("event_ts")
  sessionId      String   @map("session_id")
  playerIdHash   String   @map("player_id_hash")
  chapterId      String   @map("chapter_id")
  sceneId        String   @map("scene_id")
  npcId          String   @map("npc_id")
  dialogueNodeId String   @map("dialogue_node_id")
  choiceId       String   @map("choice_id")
  choiceTextKey  String   @map("choice_text_key")
  inputMode      String   @map("input_mode")
  latencyMs      Int?     @map("latency_ms")
  partyComp      String?  @map("party_comp")
  difficultyTier String?  @map("difficulty_tier")
  buildVersion   String   @map("build_version")
  platform       String
  region         String?
  idempotencyKey String   @unique @map("idempotency_key")
  deduped        Boolean  @default(false)
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("telemetry_dialogue_choice_events")
}
