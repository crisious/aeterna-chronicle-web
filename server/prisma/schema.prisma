generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String      @id @default(uuid())
  email     String      @unique
  password  String      // 실제로는 bcrypt 등으로 해싱하여 저장
  role      String      @default("user")  // user, moderator, admin, superadmin
  isBanned  Boolean     @default(false) @map("is_banned")
  bannedAt  DateTime?   @map("banned_at")
  banReason String?     @map("ban_reason")
  gold      Int         @default(0)
  diamond   Int         @default(0)
  crystal       Int         @default(0)  // P6-02: 프리미엄 화폐 (유료 크리스탈)
  eventCoin     Int         @default(0) @map("event_coin")
  tutorialStep  Int         @default(0) @map("tutorial_step")  // P4-13: 튜토리얼 진행 단계 (0~5)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  characters Character[]
}

// ─── 어드민 감사 로그 ───────────────────────────────────────────
model AdminAuditLog {
  id          String   @id @default(uuid())
  adminId     String   @map("admin_id")
  action      String   // user_ban, item_grant, announcement_create 등
  targetType  String   @map("target_type")  // user, item, announcement
  targetId    String?  @map("target_id")
  details     Json?
  ip          String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("admin_audit_logs")
  @@index([adminId])
  @@index([action])
  @@index([createdAt])
}

// ─── 공지사항 ───────────────────────────────────────────────────
model Announcement {
  id          String    @id @default(uuid())
  title       String
  content     String    @db.Text
  type        String    @default("info")  // info, maintenance, event, emergency
  isActive    Boolean   @default(true) @map("is_active")
  startAt     DateTime? @map("start_at")
  endAt       DateTime? @map("end_at")
  createdBy   String    @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("announcements")
}

// ─── 게임 이벤트 (어드민 관리) ──────────────────────────────────
model GameEvent {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String   @db.Text
  type        String   // login_bonus, double_drop, discount, collection, challenge
  config      Json     // 이벤트별 설정
  rewards     Json     // 보상 테이블
  startAt     DateTime @map("start_at")
  endAt       DateTime @map("end_at")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("game_events")
  @@index([type])
}

// ─── 출석 기록 ──────────────────────────────────────────────────
model AttendanceRecord {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  date      DateTime @db.Date
  day       Int      // 연속 출석일
  reward    Json     // {type, itemId?, amount}
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, date])
  @@map("attendance_records")
  @@index([userId])
}

// ─── 이벤트 진행도 ──────────────────────────────────────────────
model EventProgress {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  eventId   String   @map("event_id")
  progress  Json     // 진행 상태
  claimed   Json     @default("[]") // 수령한 보상 ID 목록
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, eventId])
  @@map("event_progress")
}

// ─── 거래 로그 ──────────────────────────────────────────────────
model TransactionLog {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  currency    String   // gold, diamond, event_coin
  amount      Int      // 양수=획득, 음수=소비
  balance     Int      // 거래 후 잔액
  reason      String   // quest_reward, shop_purchase, craft_cost 등
  referenceId String?  @map("reference_id")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("transaction_logs")
  @@index([userId])
  @@index([currency])
  @@index([createdAt])
}

model Character {
  id        String   @id @default(uuid())
  userId    String
  name      String   @unique
  classId   String   // 직업 ID (예: Warrior, Mage 등)
  level     Int      @default(1)
  exp       Int      @default(0)
  hp        Int      @default(200)
  mp        Int      @default(100)
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Phase 1 인벤토리/장비 데이터는 DB 구조 단순화를 위해 JSONB로 관리 (확장성 고려)
  inventoryData Json?

  @@index([userId])
}

// ─── 텔레메트리: 대화 선택지 이벤트 ───────────────────────────
model TelemetryDialogueChoice {
  id              String   @id @default(uuid())
  eventId         String   @map("event_id")
  eventTs         DateTime @map("event_ts")
  sessionId       String   @map("session_id")
  playerIdHash    String   @map("player_id_hash")
  chapterId       String   @map("chapter_id")
  sceneId         String   @map("scene_id")
  npcId           String   @map("npc_id")
  dialogueNodeId  String   @map("dialogue_node_id")
  choiceId        String   @map("choice_id")
  choiceTextKey   String   @map("choice_text_key")
  inputMode       String   @map("input_mode")
  latencyMs       Int?     @map("latency_ms")
  partyComp       Json?    @map("party_comp")
  difficultyTier  String?  @map("difficulty_tier")
  buildVersion    String   @map("build_version")
  platform        String
  region          String?
  idempotencyKey  String   @unique @map("idempotency_key")
  deduped         Boolean  @default(false)
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("telemetry_dialogue_choice_events")
  @@index([chapterId, sceneId, npcId])
  @@index([sessionId])
  @@index([eventTs])
  @@index([playerIdHash])
}

// ─── 텔레메트리: 범용 게임 이벤트 (향후 확장용) ─────────────────
model TelemetryGameEvent {
  id          String   @id @default(uuid())
  eventType   String   @map("event_type")
  eventTs     DateTime @map("event_ts")
  sessionId   String   @map("session_id")
  playerId    String   @map("player_id")
  payload     Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("telemetry_game_events")
  @@index([eventType, eventTs])
  @@index([sessionId])
  @@index([playerId])
}

// ─── 길드 시스템 ────────────────────────────────────────────────
model Guild {
  id          String   @id @default(uuid())
  name        String   @unique
  tag         String   @unique @db.VarChar(5)  // 길드 태그 (2~5자)
  leaderId    String   @map("leader_id")
  level       Int      @default(1)
  exp         Int      @default(0)
  maxMembers  Int      @default(30) @map("max_members")
  notice      String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  members      GuildMember[]
  wars         GuildWar[]     @relation("AttackerGuild")
  warsAsTarget GuildWar[]     @relation("DefenderGuild")

  @@map("guilds")
}

model GuildMember {
  id       String   @id @default(uuid())
  guildId  String   @map("guild_id")
  userId   String   @map("user_id")
  role     String   @default("member")  // leader, officer, member
  joinedAt DateTime @default(now()) @map("joined_at")

  guild    Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, userId])
  @@map("guild_members")
}

model GuildWar {
  id            String    @id @default(uuid())
  attackerId    String    @map("attacker_id")
  defenderId    String    @map("defender_id")
  status        String    @default("pending")  // pending, active, finished
  attackerScore Int       @default(0) @map("attacker_score")
  defenderScore Int       @default(0) @map("defender_score")
  startedAt     DateTime? @map("started_at")
  endedAt       DateTime? @map("ended_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  attacker      Guild     @relation("AttackerGuild", fields: [attackerId], references: [id])
  defender      Guild     @relation("DefenderGuild", fields: [defenderId], references: [id])

  @@map("guild_wars")
}

// ─── PvP 아레나 시스템 ──────────────────────────────────────
model PvpMatch {
  id            String    @id @default(uuid())
  player1Id     String    @map("player1_id")
  player2Id     String    @map("player2_id")
  winnerId      String?   @map("winner_id")
  player1Score  Int       @default(0) @map("player1_score")
  player2Score  Int       @default(0) @map("player2_score")
  arenaType     String    @default("ranked") @map("arena_type")  // ranked, casual, tournament
  season        Int       @default(1)
  duration      Int?      // 매치 소요 시간 (초)
  status        String    @default("matching")  // matching, ready, fighting, finished
  startedAt     DateTime? @map("started_at")
  endedAt       DateTime? @map("ended_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@map("pvp_matches")
  @@index([player1Id])
  @@index([player2Id])
  @@index([season, arenaType])
}

model PvpRating {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  season     Int      @default(1)
  rating     Int      @default(1000)
  tier       String   @default("bronze")  // bronze, silver, gold, platinum, diamond, master
  wins       Int      @default(0)
  losses     Int      @default(0)
  streak     Int      @default(0)
  peakRating Int      @default(1000) @map("peak_rating")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([userId, season])
  @@map("pvp_ratings")
  @@index([season, rating(sort: Desc)])
}

// ─── 엔딩 시스템: 엔딩 달성 기록 ────────────────────────────
model EndingRecord {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  endingType  String   @map("ending_type")
  flags       Json     // 판정 시점 플래그 스냅샷
  playthrough Int      @default(1)
  achievedAt  DateTime @default(now()) @map("achieved_at")

  @@map("ending_records")
  @@index([userId])
  @@index([endingType])
}

// ─── 상점 시스템 ────────────────────────────────────────────────
model ShopItem {
  id          String    @id @default(uuid())
  name        String
  category    String    // cosmetic, convenience, season_pass, bundle
  price       Int       // 프리미엄 화폐 가격
  currency    String    @default("crystal")  // crystal(유료), gold(무료)
  rarity      String    @default("common")   // common, rare, epic, legendary
  description String?   @db.Text
  imageUrl    String?   @map("image_url")
  isActive    Boolean   @default(true) @map("is_active")
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date")
  createdAt   DateTime  @default(now()) @map("created_at")

  purchases   Purchase[]
  @@map("shop_items")
  @@index([category, isActive])
}

model Purchase {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  itemId    String   @map("item_id")
  price     Int
  currency  String
  createdAt DateTime @default(now()) @map("created_at")

  item      ShopItem @relation(fields: [itemId], references: [id])
  @@map("purchases")
  @@index([userId])
}

// ─── 시즌 패스 시스템 ───────────────────────────────────────────
model SeasonPass {
  id             String   @id @default(uuid())
  season         Int      @unique
  name           String
  startDate      DateTime @map("start_date")
  endDate        DateTime @map("end_date")
  freeRewards    Json     @map("free_rewards")    // [{level, reward}]
  premiumRewards Json     @map("premium_rewards")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")

  progresses     SeasonPassProgress[]
  @@map("season_passes")
}

model SeasonPassProgress {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  seasonPassId   String   @map("season_pass_id")
  level          Int      @default(0)
  exp            Int      @default(0)
  isPremium      Boolean  @default(false) @map("is_premium")
  claimedFree    Json     @default("[]") @map("claimed_free")
  claimedPremium Json     @default("[]") @map("claimed_premium")
  updatedAt      DateTime @updatedAt @map("updated_at")

  seasonPass     SeasonPass @relation(fields: [seasonPassId], references: [id])
  @@unique([userId, seasonPassId])
  @@map("season_pass_progress")
}

// ─── 업적 시스템 ────────────────────────────────────────────────
model Achievement {
  id          String   @id @default(uuid())
  code        String   @unique  // "FIRST_BLOOD", "GUILD_MASTER" 등
  name        String
  description String   @db.Text
  category    String   // combat, exploration, social, collection, story
  tier        String   @default("bronze")  // bronze, silver, gold, platinum
  icon        String?
  points      Int      @default(10)
  isHidden    Boolean  @default(false) @map("is_hidden")
  condition   Json     // 달성 조건 정의 {type, target, count}
  createdAt   DateTime @default(now()) @map("created_at")

  unlocks     AchievementUnlock[]
  @@map("achievements")
  @@index([category])
}

model AchievementUnlock {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  achievementId String   @map("achievement_id")
  unlockedAt    DateTime @default(now()) @map("unlocked_at")

  achievement   Achievement @relation(fields: [achievementId], references: [id])
  @@unique([userId, achievementId])
  @@map("achievement_unlocks")
  @@index([userId])
}

model Title {
  id            String   @id @default(uuid())
  name          String   @unique
  description   String?
  rarity        String   @default("common")
  achievementId String?  @map("achievement_id")  // 연동 업적
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("titles")
}

// ─── 레이드 보스 시스템 ─────────────────────────────────────────
model RaidBoss {
  id          String   @id @default(uuid())
  name        String
  tier        String   // normal, heroic, mythic
  maxHp       Int      @map("max_hp")
  attack      Int
  defense     Int
  mechanics   Json?    // 보스 패턴/기믹 정의
  lootTable   Json     @map("loot_table")  // [{itemId, dropRate, tier}]
  minPlayers  Int      @default(4) @map("min_players")
  maxPlayers  Int      @default(10) @map("max_players")
  timeLimit   Int      @default(600) @map("time_limit")  // 초
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  sessions    RaidSession[]
  @@map("raid_bosses")
}

model RaidSession {
  id           String    @id @default(uuid())
  bossId       String    @map("boss_id")
  guildId      String?   @map("guild_id")
  status       String    @default("forming")  // forming, fighting, cleared, failed
  currentHp    Int       @map("current_hp")
  participants Json      // [{userId, damage, role}]
  startedAt    DateTime? @map("started_at")
  endedAt      DateTime? @map("ended_at")
  lootResult   Json?     @map("loot_result")
  createdAt    DateTime  @default(now()) @map("created_at")

  boss         RaidBoss  @relation(fields: [bossId], references: [id])
  @@map("raid_sessions")
  @@index([bossId])
  @@index([guildId])
  @@index([status])
}

// ─── 2차 전직 시스템 ────────────────────────────────────────────
model ClassAdvancement {
  id            String   @id @default(uuid())
  baseClass     String   @map("base_class")      // ether_knight, memory_weaver, shadow_weaver
  advancedClass String   @map("advanced_class")
  tier          Int                                // 1(Lv.30), 2(Lv.50), 3(Lv.80)
  requiredLevel Int      @map("required_level")
  questId       String?  @map("quest_id")
  skills        Json                               // 해금 스킬 목록
  statBonus     Json     @map("stat_bonus")
  ultimateSkill Json?    @map("ultimate_skill")    // tier 3만
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("class_advancements")
  @@unique([baseClass, tier])
}

// ─── 제작 시스템 ────────────────────────────────────────────────
model Recipe {
  id            String   @id @default(uuid())
  name          String   @unique
  description   String   @db.Text
  category      String   // weapon, armor, accessory, consumable, material
  resultItemId  String   @map("result_item_id")
  resultCount   Int      @default(1) @map("result_count")
  materials     Json     // [{itemId, name, count}]
  requiredLevel Int      @default(1) @map("required_level")
  craftTime     Int      @default(5) @map("craft_time")  // 초
  successRate   Float    @default(1.0) @map("success_rate")  // 0.0~1.0
  isUnlocked    Boolean  @default(true) @map("is_unlocked")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("recipes")
  @@index([category])
}

model CraftLog {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  recipeId    String   @map("recipe_id")
  success     Boolean
  resultItem  String?  @map("result_item")
  craftedAt   DateTime @default(now()) @map("crafted_at")

  @@map("craft_logs")
  @@index([userId])
}

// ─── 펫 시스템 ──────────────────────────────────────────────────
model Pet {
  id          String   @id @default(uuid())
  ownerId     String   @map("owner_id")
  name        String
  species     String   // wolf, phoenix, golem, fairy, dragon 등
  grade       String   @default("common")  // common, rare, epic, legendary
  level       Int      @default(1)
  exp         Int      @default(0)
  maxExp      Int      @default(100) @map("max_exp")
  hp          Int      @default(100)
  attack      Int      @default(10)
  defense     Int      @default(5)
  skills      Json     @default("[]")  // [{skillId, name, damage, cooldown, level}]
  bond        Int      @default(0)     // 유대감 (0~100)
  isActive    Boolean  @default(false) @map("is_active")  // 현재 소환 중
  obtainedAt  DateTime @default(now()) @map("obtained_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("pets")
  @@index([ownerId])
  @@index([species])
}

model PetSkill {
  id          String   @id @default(uuid())
  name        String   @unique
  description String   @db.Text
  damage      Int      @default(0)
  cooldown    Int      @default(10)  // 초
  effectType  String   @map("effect_type")  // damage, heal, buff, debuff
  targetType  String   @default("single") @map("target_type")  // single, aoe
  unlockLevel Int      @default(1) @map("unlock_level")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("pet_skills")
}

// ─── NPC 시스템 ─────────────────────────────────────────────────
model Npc {
  id           String   @id @default(uuid())
  name         String   @unique
  title        String?
  role         String   // merchant, quest_giver, trainer, villager, guard, boss
  location     String   // 지역 ID
  dialogue     Json     // 대화 트리 [{id, text, options: [{text, nextId, condition?}]}]
  schedule     Json?    // 시간대별 위치/행동 [{hour, location, action}]
  behaviorTree Json     @map("behavior_tree")  // 행동 트리 정의
  stats        Json?    // 전투 NPC용 스탯
  shopItems    Json?    @map("shop_items")  // 상점 NPC용 판매 목록
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("npcs")
  @@index([role])
  @@index([location])
}

// ─── 퀘스트 시스템 ──────────────────────────────────────────────
model Quest {
  id            String   @id @default(uuid())
  code          String   @unique
  name          String
  description   String   @db.Text
  type          String   // main, sub, daily, weekly, event
  chapter       Int?     // 메인 퀘스트용
  requiredLevel Int      @default(1) @map("required_level")
  prerequisites Json     @default("[]")  // 선행 퀘스트 code 목록
  objectives    Json     // [{type, target, count, description}]
  rewards       Json     // [{type, itemId?, amount, description}]
  npcId         String?  @map("npc_id")  // 수주 NPC
  timeLimit     Int?     @map("time_limit")  // 초 (일일/주간)
  isRepeatable  Boolean  @default(false) @map("is_repeatable")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("quests")
  @@index([type])
}

model QuestProgress {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  questId     String    @map("quest_id")
  status      String    @default("in_progress")  // in_progress, completed, failed, abandoned
  progress    Json      // [{objectiveIndex, current, target, completed}]
  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")

  @@unique([userId, questId])
  @@map("quest_progress")
  @@index([userId])
}

model NpcAffinity {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  npcId     String   @map("npc_id")
  level     Int      @default(0)  // 0~10
  exp       Int      @default(0)
  gifts     Json     @default("[]")  // 선물 이력
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, npcId])
  @@map("npc_affinities")
}

// ─── 소셜 시스템: 친구 ──────────────────────────────────────────
model Friendship {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  friendId  String   @map("friend_id")
  status    String   @default("pending")  // pending, accepted, blocked
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, friendId])
  @@map("friendships")
  @@index([userId])
  @@index([friendId])
}

// ─── 소셜 시스템: 파티 ──────────────────────────────────────────
model Party {
  id        String   @id @default(uuid())
  leaderId  String   @map("leader_id")
  name      String?
  maxSize   Int      @default(4) @map("max_size")
  members   Json     // [{userId, role, joinedAt}]
  status    String   @default("open")  // open, full, in_dungeon
  createdAt DateTime @default(now()) @map("created_at")

  @@map("parties")
  @@index([leaderId])
}

// ─── 아이템 마스터 데이터 (P4-09) ───────────────────────────────
model Item {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String   @db.Text
  type        String   // weapon, armor, accessory, consumable, material, quest_item
  subType     String?  @map("sub_type")  // sword, staff, dagger, plate, robe 등
  grade       String   @default("common")  // common, uncommon, rare, epic, legendary
  level       Int      @default(1)
  stats       Json?    // {attack, defense, hp, mp, critRate 등}
  price       Int      @default(0)  // 상점 가격
  sellPrice   Int      @default(0) @map("sell_price")
  stackable   Boolean  @default(false)
  maxStack    Int      @default(1) @map("max_stack")
  tradeable   Boolean  @default(true)
  icon        String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("items")
  @@index([type])
  @@index([grade])
}

// ─── 인벤토리 슬롯 (P4-09) ─────────────────────────────────────
model InventorySlot {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  itemId      String   @map("item_id")
  quantity    Int      @default(1)
  enhancement Int      @default(0)  // 강화 수치
  options     Json?    // 랜덤 옵션 [{stat, value}]
  isEquipped  Boolean  @default(false) @map("is_equipped")
  equipSlot   String?  @map("equip_slot")  // head, body, weapon, shield, ring, necklace
  obtainedAt  DateTime @default(now()) @map("obtained_at")

  @@map("inventory_slots")
  @@index([userId])
  @@index([itemId])
}

// ─── 소셜 시스템: 우편 ──────────────────────────────────────────
model Mail {
  id          String    @id @default(uuid())
  senderId    String?   @map("sender_id")  // null = 시스템 우편
  receiverId  String    @map("receiver_id")
  subject     String
  body        String    @db.Text
  attachments Json?     // [{itemId, count}]
  isRead      Boolean   @default(false) @map("is_read")
  isCollected Boolean   @default(false) @map("is_collected")  // 첨부 수령 여부
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("mails")
  @@index([receiverId])
  @@index([senderId])
}

// ─── 몬스터/적 시스템 (P5-01) ───────────────────────────────────
model Monster {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  type        String   // normal, elite, boss, field_boss, raid_boss
  element     String   @default("neutral")  // neutral, fire, ice, lightning, earth, dark, light, time, aether
  level       Int
  hp          Int
  attack      Int
  defense     Int
  speed       Int
  skills      Json     @default("[]")  // [{name, damage, cooldown, element, effectType}]
  dropTable   Json     @map("drop_table")  // [{itemId, rate, minQty, maxQty}]
  expReward   Int      @map("exp_reward")
  goldReward  Int      @map("gold_reward")
  behavior    Json     // 행동 패턴 {aggro_range, patrol, flee_hp_pct, enrage_hp_pct}
  location    String?  // 출현 지역
  respawnTime Int      @default(30) @map("respawn_time")  // 초
  lore        String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("monsters")
  @@index([type])
  @@index([level])
  @@index([location])
}

model MonsterSpawn {
  id        String  @id @default(uuid())
  monsterId String  @map("monster_id")
  zoneId    String  @map("zone_id")
  posX      Float   @map("pos_x")
  posY      Float   @map("pos_y")
  maxCount  Int     @default(3) @map("max_count")
  isActive  Boolean @default(true) @map("is_active")

  @@map("monster_spawns")
  @@index([zoneId])
}

// ─── 스킬 트리 시스템 (P5-02) ───────────────────────────────
model Skill {
  id            String   @id @default(uuid())
  code          String   @unique
  name          String
  description   String   @db.Text
  class         String   // ether_knight, memory_weaver, shadow_weaver
  tier          Int      // 1(기본), 2(Lv.30전직), 3(Lv.50전직), 4(Lv.80전직)
  type          String   // active, passive, ultimate
  element       String   @default("neutral")
  damage        Int      @default(0)
  damageScale   Float    @default(1.0) @map("damage_scale")
  mpCost        Int      @default(0) @map("mp_cost")
  cooldown      Float    @default(0)
  castTime      Float    @default(0) @map("cast_time")
  range         Float    @default(1)
  targetType    String   @default("single") @map("target_type")
  aoeRadius     Float?   @map("aoe_radius")
  effect        Json?
  maxLevel      Int      @default(5) @map("max_level")
  levelScaling  Json     @map("level_scaling")
  prerequisites Json     @default("[]")
  requiredLevel Int      @default(1) @map("required_level")
  icon          String?
  animation     String?
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("skills")
  @@index([class])
  @@index([tier])
}

model PlayerSkill {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  skillId     String   @map("skill_id")
  level       Int      @default(1)
  isEquipped  Boolean  @default(false) @map("is_equipped")
  slotIndex   Int?     @map("slot_index")
  unlockedAt  DateTime @default(now()) @map("unlocked_at")

  @@unique([userId, skillId])
  @@map("player_skills")
  @@index([userId])
}

// ─── 던전 시스템 (P5-03) ────────────────────────────────────────
model Dungeon {
  id            String   @id @default(uuid())
  code          String   @unique
  name          String
  description   String   @db.Text
  zoneId        String   @map("zone_id")
  difficulty    String   @default("normal")  // normal, hard, nightmare
  requiredLevel Int      @map("required_level")
  maxPlayers    Int      @default(4) @map("max_players")
  waves         Json     // [{wave, monsters: [{monsterId, count}], isBoss}]
  rewards       Json     // 클리어 보상
  timeLimit     Int      @default(600) @map("time_limit")
  entryCount    Int      @default(3) @map("entry_count")  // 일일 입장 횟수
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("dungeons")
  @@index([zoneId])
  @@index([difficulty])
}

model DungeonRun {
  id          String    @id @default(uuid())
  dungeonId   String    @map("dungeon_id")
  leaderId    String    @map("leader_id")
  members     Json      // [{userId, damage, deaths}]
  status      String    @default("in_progress")  // in_progress, cleared, failed, abandoned
  currentWave Int       @default(1) @map("current_wave")
  startedAt   DateTime  @default(now()) @map("started_at")
  endedAt     DateTime? @map("ended_at")
  lootResult  Json?     @map("loot_result")

  @@map("dungeon_runs")
  @@index([dungeonId])
  @@index([leaderId])
}

// ─── 월드맵/필드 시스템 (P5-04) ─────────────────────────────────
model Zone {
  id            String   @id @default(uuid())
  code          String   @unique
  name          String
  description   String   @db.Text
  region        String   // argentium, silvanhome, erebos, solaris, northland, britallia, oblivion_plateau
  levelRange    Json     @map("level_range")  // {min, max}
  connections   Json     // 인접 존 코드 목록
  npcs          Json     @default("[]")  // 배치된 NPC 목록
  ambientSound  String?  @map("ambient_sound")
  bgm           String?
  mapData       Json?    @map("map_data")  // 타일맵 데이터
  isHub         Boolean  @default(false) @map("is_hub")  // 마을/안전지대
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("zones")
  @@index([region])
}

model PlayerLocation {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  zoneId    String   @map("zone_id")
  posX      Float    @default(0) @map("pos_x")
  posY      Float    @default(0) @map("pos_y")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("player_locations")
}

// ─── 도감/컬렉션 시스템 (P5-08) ─────────────────────────────────
model CodexEntry {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  category    String   // monster, item, npc, zone, skill
  targetCode  String   @map("target_code")
  discovered  Boolean  @default(true)
  percentage  Float    @default(0)
  unlockedAt  DateTime @default(now()) @map("unlocked_at")

  @@unique([userId, category, targetCode])
  @@map("codex_entries")
  @@index([userId])
  @@index([category])
}

// ─── 알림 시스템 (P5-10) ────────────────────────────────────────
model Notification {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  type        String   // system, achievement, mail, guild, pvp, quest, event, social
  title       String
  message     String
  data        Json?
  isRead      Boolean  @default(false) @map("is_read")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("notifications")
  @@index([userId, isRead])
  @@index([createdAt])
}

// ─── 거래소/경매장 (P5-06) ──────────────────────────────────────
model AuctionListing {
  id          String   @id @default(uuid())
  sellerId    String   @map("seller_id")
  itemId      String   @map("item_id")
  slotId      String   @map("slot_id")
  quantity    Int      @default(1)
  priceType   String   @default("gold") @map("price_type")
  buyoutPrice Int      @map("buyout_price")
  bidPrice    Int?     @map("bid_price")
  currentBid  Int?     @map("current_bid")
  bidderId    String?  @map("bidder_id")
  status      String   @default("active")  // active, sold, expired, cancelled
  fee         Int      @default(0)  // 등록 수수료
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("auction_listings")
  @@index([sellerId])
  @@index([itemId])
  @@index([status])
  @@index([expiresAt])
}

// ─── 통합 랭킹 (P5-07) ─────────────────────────────────────────
model RankingEntry {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  category    String   // level, combat_power, pvp_rating, raid_clear, achievement_points
  score       Float
  rank        Int?
  season      String?
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([userId, category, season])
  @@map("ranking_entries")
  @@index([category, score])
}

// ─── 결제 영수증 (P6-02) ────────────────────────────────────────
model PaymentReceipt {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  platform      String    // web, ios, android
  productId     String    @map("product_id")
  amount        Int       // 실제 결제금액 (원)
  currency      String    @default("KRW")
  crystalAmount Int       @map("crystal_amount")
  receiptData   String?   @map("receipt_data") @db.Text
  status        String    @default("pending") // pending, verified, failed, refunded
  refundStatus  String?   @map("refund_status")
  verifiedAt    DateTime? @map("verified_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@map("payment_receipts")
  @@index([userId])
  @@index([status])
}

// ─── 코스메틱 아이템 (P6-03) ────────────────────────────────────
model CosmeticItem {
  id            String    @id @default(uuid())
  code          String    @unique
  name          String
  category      String    // skin, weapon_skin, pet_skin, mount, emote, title_effect
  rarity        String    @default("rare") // rare, epic, legendary
  priceType     String    @map("price_type") // crystal, gold, season_reward
  price         Int
  affectsStats  Boolean   @default(false) @map("affects_stats") // P2W 가드: 반드시 false
  preview       String?   // 미리보기 이미지 경로
  description   String?   @db.Text
  isLimited     Boolean   @default(false) @map("is_limited")
  availableFrom DateTime? @map("available_from")
  availableTo   DateTime? @map("available_to")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@map("cosmetic_items")
  @@index([category])
}

// ─── 플레이어 코스메틱 보유/장착 (P6-03) ────────────────────────
model PlayerCosmetic {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  cosmeticId   String   @map("cosmetic_id")
  isEquipped   Boolean  @default(false) @map("is_equipped")
  equippedSlot String?  @map("equipped_slot")
  acquiredAt   DateTime @default(now()) @map("acquired_at")

  @@unique([userId, cosmeticId])
  @@map("player_cosmetics")
  @@index([userId])
}
