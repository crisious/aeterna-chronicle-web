generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String      @id @default(uuid())
  email     String      @unique
  username  String?
  name      String?
  password  String
  role      String      @default("user")
  isBanned  Boolean     @default(false) @map("is_banned")
  bannedAt  DateTime?   @map("banned_at")
  banReason    String?     @map("ban_reason")
  banExpiresAt DateTime?  @map("ban_expires_at")
  gold      Int         @default(0)
  diamond   Int         @default(0)
  crystal       Int         @default(0)  // P6-02: 프리미엄 화폐 (유료 크리스탈)
  eventCoin     Int         @default(0) @map("event_coin")
  tutorialStep  Int         @default(0) @map("tutorial_step")  // P4-13: 튜토리얼 진행 단계 (0~5)
  lastLoginAt   DateTime?   @map("last_login_at")  // P6-14: DAU/MAU 집계용
  nickname      String?     // P6-13: 어드민 대시보드 표시용
  level         Int         @default(1)  // P6-13: 어드민 대시보드 표시용
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  characters Character[]
  partyMembers PartyMember[]
  equipment    Equipment[]

  // P7-14: DAU/MAU 집계 + 밴 필터 + 역할 조회 최적화
  @@index([lastLoginAt])
  @@index([isBanned])
  @@index([role])
  @@index([createdAt])
}

// ─── 어드민 감사 로그 ───────────────────────────────────────────
model AdminAuditLog {
  id          String   @id @default(uuid())
  adminId     String   @map("admin_id")
  action      String   // user_ban, item_grant, announcement_create 등
  targetType  String   @map("target_type")  // user, item, announcement
  targetId    String?  @map("target_id")
  details     Json?
  ip          String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("admin_audit_logs")
  @@index([adminId])
  @@index([action])
  @@index([createdAt])
}

// ─── 공지사항 ───────────────────────────────────────────────────
model Announcement {
  id          String    @id @default(uuid())
  title       String
  content     String    @db.Text
  type        String    @default("info")  // info, maintenance, event, emergency
  isActive    Boolean   @default(true) @map("is_active")
  startAt     DateTime? @map("start_at")
  endAt       DateTime? @map("end_at")
  createdBy   String    @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("announcements")
  // P7-14: 활성 공지 조회 최적화
  @@index([isActive, startAt, endAt])
}

// ─── 게임 이벤트 (어드민 관리) ──────────────────────────────────
model GameEvent {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String   @db.Text
  type        String   // login_bonus, double_drop, discount, collection, challenge
  config      Json     // 이벤트별 설정
  rewards     Json     // 보상 테이블
  startAt     DateTime @map("start_at")
  endAt       DateTime @map("end_at")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("game_events")
  @@index([type])
  // P7-14: 활성 이벤트 조회 + 기간 필터 최적화
  @@index([isActive, startAt, endAt])
}

// ─── 출석 기록 ──────────────────────────────────────────────────
model AttendanceRecord {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  date      DateTime @db.Date
  day       Int      // 연속 출석일
  reward    Json     // {type, itemId?, amount}
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, date])
  @@map("attendance_records")
  @@index([userId])
}

// ─── 이벤트 진행도 ──────────────────────────────────────────────
model EventProgress {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  eventId   String   @map("event_id")
  progress  Json     // 진행 상태
  claimed   Json     @default("[]") // 수령한 보상 ID 목록
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, eventId])
  @@map("event_progress")
}

// ─── 거래 로그 ──────────────────────────────────────────────────
model TransactionLog {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  currency    String   // gold, diamond, event_coin
  amount      Int      // 양수=획득, 음수=소비
  balance     Int      // 거래 후 잔액
  reason      String   // quest_reward, shop_purchase, craft_cost 등
  referenceId String?  @map("reference_id")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("transaction_logs")
  @@index([userId])
  @@index([currency])
  @@index([createdAt])
}

model Character {
  id              String   @id @default(uuid())
  userId          String
  accountId       String?  @map("account_id")
  name            String   @unique
  classId         String
  level           Int      @default(1)
  exp             Int      @default(0)
  hp              Int      @default(200)
  maxHp           Int      @default(200) @map("max_hp")
  mp              Int      @default(100)
  maxMp           Int      @default(100) @map("max_mp")
  gold            Int      @default(0)
  guildId         String?  @map("guild_id")
  isActive        Boolean  @default(true) @map("is_active")
  seasonPassLevel Int      @default(0) @map("season_pass_level")
  playTimeHours   Float    @default(0) @map("play_time_hours")
  chapterProgress Int      @default(0) @map("chapter_progress")
  statPoints      Int      @default(0) @map("stat_points")
  user            User     @relation(fields: [userId], references: [id])
  inventoryItems  InventoryItem[] @relation("CharacterInventory")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  inventoryData   Json?

  @@index([userId])
  @@index([classId, level])
  @@index([accountId])
}

// ─── 텔레메트리: 대화 선택지 이벤트 ───────────────────────────
model TelemetryDialogueChoice {
  id              String   @id @default(uuid())
  eventId         String   @map("event_id")
  eventTs         DateTime @map("event_ts")
  sessionId       String   @map("session_id")
  playerIdHash    String   @map("player_id_hash")
  chapterId       String   @map("chapter_id")
  sceneId         String   @map("scene_id")
  npcId           String   @map("npc_id")
  dialogueNodeId  String   @map("dialogue_node_id")
  choiceId        String   @map("choice_id")
  choiceTextKey   String   @map("choice_text_key")
  inputMode       String   @map("input_mode")
  latencyMs       Int?     @map("latency_ms")
  partyComp       Json?    @map("party_comp")
  difficultyTier  String?  @map("difficulty_tier")
  buildVersion    String   @map("build_version")
  platform        String
  region          String?
  idempotencyKey  String   @unique @map("idempotency_key")
  deduped         Boolean  @default(false)
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("telemetry_dialogue_choice_events")
  @@index([chapterId, sceneId, npcId])
  @@index([sessionId])
  @@index([eventTs])
  @@index([playerIdHash])
}

// ─── 텔레메트리: 범용 게임 이벤트 (향후 확장용) ─────────────────
model TelemetryGameEvent {
  id          String   @id @default(uuid())
  eventType   String   @map("event_type")
  eventTs     DateTime @map("event_ts")
  sessionId   String   @map("session_id")
  playerId    String   @map("player_id")
  payload     Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("telemetry_game_events")
  @@index([eventType, eventTs])
  @@index([sessionId])
  @@index([playerId])
}

// ─── 길드 시스템 ────────────────────────────────────────────────
model Guild {
  id          String   @id @default(uuid())
  name        String   @unique
  tag         String   @unique @db.VarChar(5)  // 길드 태그 (2~5자)
  leaderId    String   @map("leader_id")
  level       Int      @default(1)
  exp         Int      @default(0)
  gold        Int      @default(0)  // P7-03: 길드 골드 (스킬 해금/업그레이드 비용)
  maxMembers  Int      @default(30) @map("max_members")
  memberCount Int      @default(0) @map("member_count")
  notice      String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  members      GuildMember[]
  skills       GuildSkill[]
  wars         GuildWar[]     @relation("AttackerGuild")
  warsAsTarget GuildWar[]     @relation("DefenderGuild")

  @@map("guilds")
}

model GuildMember {
  id       String   @id @default(uuid())
  guildId  String   @map("guild_id")
  userId   String   @map("user_id")
  role     String   @default("member")  // leader, officer, member
  joinedAt DateTime @default(now()) @map("joined_at")

  guild    Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, userId])
  @@map("guild_members")
}

// ─── 길드 스킬 (P6-06) ──────────────────────────────────────
model GuildSkill {
  id          String   @id @default(uuid())
  guildId     String   @map("guild_id")
  skillCode   String   @map("skill_code")
  level       Int      @default(1)
  unlockedAt  DateTime @default(now()) @map("unlocked_at")

  guild       Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, skillCode])
  @@map("guild_skills")
}

// ─── 길드전 (P6-07 거점 점령전 확장) ────────────────────────
model GuildWar {
  id            String    @id @default(uuid())
  attackerId    String    @map("attacker_id")
  defenderId    String    @map("defender_id")
  status        String    @default("pending")  // pending, matching, active, finished
  attackerScore Int       @default(0) @map("attacker_score")
  defenderScore Int       @default(0) @map("defender_score")
  winnerId      String?   @map("winner_id")       // 승리 길드 ID
  fortressA     String?   @map("fortress_a")       // 거점 A 점령 길드 ID
  fortressB     String?   @map("fortress_b")       // 거점 B 점령 길드 ID
  fortressC     String?   @map("fortress_c")       // 거점 C 점령 길드 ID
  rewardClaimed Boolean   @default(false) @map("reward_claimed")
  startedAt     DateTime? @map("started_at")
  endedAt       DateTime? @map("ended_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  attacker      Guild     @relation("AttackerGuild", fields: [attackerId], references: [id])
  defender      Guild     @relation("DefenderGuild", fields: [defenderId], references: [id])

  @@map("guild_wars")
  @@index([status])
}

// ─── PvP 아레나 시스템 ──────────────────────────────────────
model PvpMatch {
  id            String    @id @default(uuid())
  player1Id     String    @map("player1_id")
  player2Id     String    @map("player2_id")
  winnerId      String?   @map("winner_id")
  player1Score  Int       @default(0) @map("player1_score")
  player2Score  Int       @default(0) @map("player2_score")
  arenaType     String    @default("ranked") @map("arena_type")  // ranked, casual, tournament
  season        Int       @default(1)
  duration      Int?      // 매치 소요 시간 (초)
  status        String    @default("matching")  // matching, ready, fighting, finished
  startedAt     DateTime? @map("started_at")
  endedAt       DateTime? @map("ended_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@map("pvp_matches")
  @@index([player1Id])
  @@index([player2Id])
  @@index([season, arenaType])
}

model PvpRating {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  season     Int      @default(1)
  rating     Int      @default(1000)
  tier       String   @default("bronze")  // bronze, silver, gold, platinum, diamond, master
  wins       Int      @default(0)
  losses     Int      @default(0)
  streak     Int      @default(0)
  peakRating Int      @default(1000) @map("peak_rating")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([userId, season])
  @@map("pvp_ratings")
  @@index([season, rating(sort: Desc)])
}

// ─── 엔딩 시스템: 엔딩 달성 기록 ────────────────────────────
model EndingRecord {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  endingType  String   @map("ending_type")
  flags       Json     // 판정 시점 플래그 스냅샷
  playthrough Int      @default(1)
  achievedAt  DateTime @default(now()) @map("achieved_at")

  @@map("ending_records")
  @@index([userId])
  @@index([endingType])
}

// ─── 상점 시스템 ────────────────────────────────────────────────
model ShopItem {
  id          String    @id @default(uuid())
  name        String
  category    String    // cosmetic, convenience, season_pass, bundle
  price       Int       // 프리미엄 화폐 가격
  currency    String    @default("crystal")  // crystal(유료), gold(무료)
  rarity      String    @default("common")   // common, rare, epic, legendary
  description String?   @db.Text
  imageUrl    String?   @map("image_url")
  isActive    Boolean   @default(true) @map("is_active")
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date")
  createdAt   DateTime  @default(now()) @map("created_at")

  purchases   Purchase[]
  @@map("shop_items")
  @@index([category, isActive])
  // P7-14: 기간 한정 상품 조회 최적화
  @@index([isActive, startDate, endDate])
  @@index([currency])
}

model Purchase {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  itemId    String   @map("item_id")
  price     Int
  currency  String
  createdAt DateTime @default(now()) @map("created_at")

  item      ShopItem @relation(fields: [itemId], references: [id])
  @@map("purchases")
  @@index([userId])
  // P7-14: 아이템별 매출 분석 + 기간 필터
  @@index([itemId])
  @@index([createdAt])
  @@index([userId, createdAt])
}

// ─── 시즌 패스 시스템 ───────────────────────────────────────────
model SeasonPass {
  id             String   @id @default(uuid())
  season         Int      @unique
  name           String
  startDate      DateTime @map("start_date")
  endDate        DateTime @map("end_date")
  freeRewards    Json     @map("free_rewards")    // [{level, reward}]
  premiumRewards Json     @map("premium_rewards")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")

  progresses     SeasonPassProgress[]
  @@map("season_passes")
}

model SeasonPassProgress {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  seasonId       String?  @map("season_id")
  seasonPassId   String   @map("season_pass_id")
  level          Int      @default(0)
  exp            Int      @default(0)
  isPremium      Boolean  @default(false) @map("is_premium")
  claimedFree    Json     @default("[]") @map("claimed_free")
  claimedPremium Json     @default("[]") @map("claimed_premium")
  updatedAt      DateTime @updatedAt @map("updated_at")

  seasonPass     SeasonPass @relation(fields: [seasonPassId], references: [id])
  @@unique([userId, seasonPassId])
  @@map("season_pass_progress")
}

// ─── 업적 시스템 ────────────────────────────────────────────────
model Achievement {
  id          String   @id @default(uuid())
  code        String   @unique  // "FIRST_BLOOD", "GUILD_MASTER" 등
  name        String
  description String   @db.Text
  category    String   // combat, exploration, social, collection, story
  tier        String   @default("bronze")  // bronze, silver, gold, platinum
  icon        String?
  iconUrl     String?  @map("icon_url")
  points      Int      @default(10)
  isHidden    Boolean  @default(false) @map("is_hidden")
  condition   Json     // 달성 조건 정의 {type, target, count}
  reward      String?  @db.Text  // 보상 JSON (nullable)
  createdAt   DateTime @default(now()) @map("created_at")

  unlocks           AchievementUnlock[]
  userAchievements  UserAchievement[]
  @@map("achievements")
  @@index([category])
}

model AchievementUnlock {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  achievementId String   @map("achievement_id")
  unlockedAt    DateTime @default(now()) @map("unlocked_at")

  achievement   Achievement @relation(fields: [achievementId], references: [id])
  @@unique([userId, achievementId])
  @@map("achievement_unlocks")
  @@index([userId])
}

model Title {
  id            String   @id @default(uuid())
  name          String?  @unique
  description   String?
  rarity        String   @default("common")
  achievementId String?  @map("achievement_id")
  userId        String?  @map("user_id")
  titleId       String?  @map("title_id")
  earnedAt      DateTime? @map("earned_at")
  createdAt     DateTime @default(now()) @map("created_at")

  userTitles    UserTitle[]

  @@map("titles")
}

// ─── 유저 칭호 소유 (P7-07) ─────────────────────────────────────
model UserTitle {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  titleId    String    @map("title_id")
  equippedAt DateTime? @map("equipped_at")  // null이면 미장착, 값이 있으면 현재 장착 중
  grantedAt  DateTime  @default(now()) @map("granted_at")

  title      Title     @relation(fields: [titleId], references: [id], onDelete: Cascade)

  @@unique([userId, titleId])
  @@map("user_titles")
  @@index([userId])
}

// ─── 레이드 보스 시스템 ─────────────────────────────────────────
model RaidBoss {
  id          String   @id @default(uuid())
  name        String
  tier        String   // normal, heroic, mythic
  maxHp       Int      @map("max_hp")
  attack      Int
  defense     Int
  mechanics   Json?    // 보스 패턴/기믹 정의
  lootTable   Json     @map("loot_table")  // [{itemId, dropRate, tier}]
  minPlayers  Int      @default(4) @map("min_players")
  maxPlayers  Int      @default(10) @map("max_players")
  timeLimit   Int      @default(600) @map("time_limit")  // 초
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  sessions    RaidSession[]
  @@map("raid_bosses")
}

model RaidSession {
  id           String    @id @default(uuid())
  bossId       String    @map("boss_id")
  guildId      String?   @map("guild_id")
  status       String    @default("forming")  // forming, fighting, cleared, failed
  currentHp    Int       @map("current_hp")
  participants Json      // [{userId, damage, role}]
  startedAt    DateTime? @map("started_at")
  endedAt      DateTime? @map("ended_at")
  lootResult   Json?     @map("loot_result")
  createdAt    DateTime  @default(now()) @map("created_at")

  boss         RaidBoss  @relation(fields: [bossId], references: [id])
  @@map("raid_sessions")
  @@index([bossId])
  @@index([guildId])
  @@index([status])
}

// ─── 2차 전직 시스템 ────────────────────────────────────────────
model ClassAdvancement {
  id            String   @id @default(uuid())
  baseClass     String   @map("base_class")      // ether_knight, memory_weaver, shadow_weaver
  advancedClass String   @map("advanced_class")
  tier          Int                                // 1(Lv.30), 2(Lv.50), 3(Lv.80)
  requiredLevel Int      @map("required_level")
  questId       String?  @map("quest_id")
  skills        Json                               // 해금 스킬 목록
  statBonus     Json     @map("stat_bonus")
  ultimateSkill Json?    @map("ultimate_skill")    // tier 3만
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("class_advancements")
  @@unique([baseClass, tier])
}

// ─── 제작 시스템 ────────────────────────────────────────────────
model Recipe {
  id            String   @id @default(uuid())
  name          String   @unique
  description   String   @db.Text
  category      String   // weapon, armor, accessory, consumable, material
  resultItemId  String   @map("result_item_id")
  resultCount   Int      @default(1) @map("result_count")
  materials     Json     // [{itemId, name, count}]
  requiredLevel Int      @default(1) @map("required_level")
  craftTime     Int      @default(5) @map("craft_time")  // 초
  successRate   Float    @default(1.0) @map("success_rate")  // 0.0~1.0
  isUnlocked    Boolean  @default(true) @map("is_unlocked")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("recipes")
  @@index([category])
}

model CraftLog {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  recipeId    String   @map("recipe_id")
  success     Boolean
  resultItem  String?  @map("result_item")
  craftedAt   DateTime @default(now()) @map("crafted_at")

  @@map("craft_logs")
  @@index([userId])
}

// ─── 펫 시스템 ──────────────────────────────────────────────────
model Pet {
  id              String    @id @default(uuid())
  ownerId         String    @map("owner_id")
  name            String
  species         String
  family          String?
  grade           String    @default("common")
  level           Int       @default(1)
  exp             Int       @default(0)
  maxExp          Int       @default(100) @map("max_exp")
  hp              Int       @default(100)
  attack          Int       @default(10)
  defense         Int       @default(5)
  affinity        Int       @default(0)
  evolutionStage  String    @default("baby") @map("evolution_stage")
  appearanceKey   String?   @map("appearance_key")
  skills          Json      @default("[]")
  bond            Int       @default(0)
  isActive        Boolean   @default(false) @map("is_active")
  obtainedAt      DateTime  @default(now()) @map("obtained_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  petSkills       PetSkill[]

  @@map("pets")
  @@index([ownerId])
  @@index([species])
}

model PetSkill {
  id          String    @id @default(uuid())
  petId       String    @map("pet_id")
  skillId     String    @map("skill_id")
  name        String?
  description String?   @db.Text
  damage      Int       @default(0)
  cooldown    Int       @default(10)
  effectType  String?   @map("effect_type")
  targetType  String    @default("single") @map("target_type")
  unlockLevel Int       @default(1) @map("unlock_level")
  unlockedAt  DateTime? @map("unlocked_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  pet         Pet       @relation(fields: [petId], references: [id])
  @@unique([petId, skillId])
  @@map("pet_skills")
  @@index([petId])
}

// ─── NPC 시스템 ─────────────────────────────────────────────────
model Npc {
  id           String   @id @default(uuid())
  name         String   @unique
  title        String?
  role         String   // merchant, quest_giver, trainer, villager, guard, boss
  location     String   // 지역 ID
  dialogue     Json     // 대화 트리 [{id, text, options: [{text, nextId, condition?}]}]
  schedule     Json?    // 시간대별 위치/행동 [{hour, location, action}]
  behaviorTree Json     @map("behavior_tree")  // 행동 트리 정의
  stats        Json?    // 전투 NPC용 스탯
  shopItems    Json?    @map("shop_items")  // 상점 NPC용 판매 목록
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("npcs")
  @@index([role])
  @@index([location])
}

// ─── 퀘스트 시스템 ──────────────────────────────────────────────
model Quest {
  id            String   @id @default(uuid())
  code          String   @unique
  name          String
  description   String   @db.Text
  type          String   // main, sub, daily, weekly, event
  chapter       Int?     // 메인 퀘스트용
  requiredLevel Int      @default(1) @map("required_level")
  prerequisites Json     @default("[]")  // 선행 퀘스트 code 목록
  objectives    Json     // [{type, target, count, description}]
  rewards       Json     // [{type, itemId?, amount, description}]
  npcId         String?  @map("npc_id")  // 수주 NPC
  timeLimit     Int?     @map("time_limit")  // 초 (일일/주간)
  isRepeatable        Boolean  @default(false) @map("is_repeatable")
  isActive            Boolean  @default(true) @map("is_active")
  tags                Json?
  difficulty          Int?
  dailyCompletionCount Int     @default(0) @map("daily_completion_count")
  createdAt           DateTime @default(now()) @map("created_at")

  @@map("quests")
  @@index([type])
}

model QuestProgress {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  characterId String?   @map("character_id")
  questId     String    @map("quest_id")
  status      String    @default("in_progress")  // in_progress, completed, failed, abandoned
  progress    Json      // [{objectiveIndex, current, target, completed}]
  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")

  @@unique([userId, questId])
  @@map("quest_progress")
  @@index([userId])
  // P7-14: 상태별 퀘스트 조회 (진행 중/완료)
  @@index([userId, status])
}

model NpcAffinity {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  npcId     String   @map("npc_id")
  level     Int      @default(0)  // 0~10
  exp       Int      @default(0)
  gifts     Json     @default("[]")  // 선물 이력
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, npcId])
  @@map("npc_affinities")
}

// ─── 소셜 시스템: 친구 ──────────────────────────────────────────
model Friendship {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  friendId  String   @map("friend_id")
  status    String   @default("pending")  // pending, accepted, blocked
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, friendId])
  @@map("friendships")
  @@index([userId])
  @@index([friendId])
}

// ─── 소셜 시스템: 파티 ──────────────────────────────────────────
model Party {
  id        String        @id @default(uuid())
  leaderId  String        @map("leader_id")
  name      String?
  maxSize   Int           @default(4) @map("max_size")
  status    String        @default("open")  // open, full, in_dungeon
  createdAt DateTime      @default(now()) @map("created_at")
  members   PartyMember[]
  invites   PartyInvite[]

  @@map("parties")
  @@index([leaderId])
}

// ─── 아이템 마스터 데이터 (P4-09) ───────────────────────────────
model Item {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String   @db.Text
  type        String   // weapon, armor, accessory, consumable, material, quest_item
  subType     String?  @map("sub_type")  // sword, staff, dagger, plate, robe 등
  grade       String   @default("common")  // common, uncommon, rare, epic, legendary
  level       Int      @default(1)
  stats       Json?    // {attack, defense, hp, mp, critRate 등}
  price       Int      @default(0)  // 상점 가격
  sellPrice   Int      @default(0) @map("sell_price")
  stackable   Boolean  @default(false)
  maxStack    Int      @default(1) @map("max_stack")
  tradeable        Boolean  @default(true)
  icon             String?
  isActive         Boolean  @default(true) @map("is_active")
  tags             Json?
  requiredLevel    Int?     @map("required_level")
  classRestriction String?  @map("class_restriction")
  dailyUsageCount  Int      @default(0) @map("daily_usage_count")
  createdAt        DateTime @default(now()) @map("created_at")

  @@map("items")
  @@index([type])
  @@index([grade])
}

// ─── 인벤토리 슬롯 (P4-09) ─────────────────────────────────────
model InventorySlot {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  itemId      String   @map("item_id")
  quantity    Int      @default(1)
  enhancement Int      @default(0)  // 강화 수치
  options     Json?    // 랜덤 옵션 [{stat, value}]
  isEquipped  Boolean  @default(false) @map("is_equipped")
  equipSlot   String?  @map("equip_slot")  // head, body, weapon, shield, ring, necklace
  obtainedAt  DateTime @default(now()) @map("obtained_at")

  @@map("inventory_slots")
  @@index([userId])
  @@index([itemId])
}

// ─── 소셜 시스템: 우편 ──────────────────────────────────────────
model Mail {
  id          String    @id @default(uuid())
  senderId    String?   @map("sender_id")  // null = 시스템 우편
  receiverId  String    @map("receiver_id")
  subject     String
  body        String    @db.Text
  attachments Json?     // [{itemId, count}]
  isRead      Boolean   @default(false) @map("is_read")
  isCollected Boolean   @default(false) @map("is_collected")  // 첨부 수령 여부
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("mails")
  @@index([receiverId])
  @@index([senderId])
  // P7-14: 읽지 않은 우편 + 만료 우편 정리 최적화
  @@index([receiverId, isRead])
  @@index([expiresAt])
}

// ─── 몬스터/적 시스템 (P5-01) ───────────────────────────────────
model Monster {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  type        String   // normal, elite, boss, field_boss, raid_boss
  element     String   @default("neutral")  // neutral, fire, ice, lightning, earth, dark, light, time, aether
  level       Int
  hp          Int
  attack      Int
  defense     Int
  speed       Int
  skills      Json     @default("[]")  // [{name, damage, cooldown, element, effectType}]
  dropTable   Json     @map("drop_table")  // [{itemId, rate, minQty, maxQty}]
  expReward   Int      @map("exp_reward")
  goldReward  Int      @map("gold_reward")
  behavior    Json     // 행동 패턴 {aggro_range, patrol, flee_hp_pct, enrage_hp_pct}
  location    String?  // 출현 지역
  respawnTime Int      @default(30) @map("respawn_time")  // 초
  lore        String?  @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("monsters")
  @@index([type])
  @@index([level])
  @@index([location])
}

model MonsterSpawn {
  id        String  @id @default(uuid())
  monsterId String  @map("monster_id")
  zoneId    String  @map("zone_id")
  posX      Float   @map("pos_x")
  posY      Float   @map("pos_y")
  maxCount  Int     @default(3) @map("max_count")
  isActive  Boolean @default(true) @map("is_active")

  @@map("monster_spawns")
  @@index([zoneId])
}

// ─── 스킬 트리 시스템 (P5-02) ───────────────────────────────
model Skill {
  id            String   @id @default(uuid())
  code          String   @unique
  name          String
  description   String   @db.Text
  class         String   // ether_knight, memory_weaver, shadow_weaver
  tier          Int      // 1(기본), 2(Lv.30전직), 3(Lv.50전직), 4(Lv.80전직)
  type          String   // active, passive, ultimate
  element       String   @default("neutral")
  damage        Int      @default(0)
  damageScale   Float    @default(1.0) @map("damage_scale")
  mpCost        Int      @default(0) @map("mp_cost")
  cooldown      Float    @default(0)
  castTime      Float    @default(0) @map("cast_time")
  range         Float    @default(1)
  targetType    String   @default("single") @map("target_type")
  aoeRadius     Float?   @map("aoe_radius")
  effect        Json?
  maxLevel      Int      @default(5) @map("max_level")
  levelScaling  Json     @map("level_scaling")
  prerequisites Json     @default("[]")
  requiredLevel Int      @default(1) @map("required_level")
  icon          String?
  animation     String?
  isActive      Boolean  @default(true) @map("is_active")
  // D-S4: 분기 그룹 ID (null = 분기 외, 같은 group skill 들 간 mutually exclusive)
  branchGroup   String?  @map("branch_group")
  createdAt     DateTime @default(now()) @map("created_at")

  playerSkills  PlayerSkill[]
  @@map("skills")
  @@index([class])
  @@index([tier])
}

model PlayerSkill {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  characterId String?  @map("character_id")
  skillId     String   @map("skill_id")
  level       Int      @default(1)
  isEquipped  Boolean  @default(false) @map("is_equipped")
  slotIndex   Int?     @map("slot_index")
  unlockedAt  DateTime @default(now()) @map("unlocked_at")

  skill       Skill    @relation(fields: [skillId], references: [id])
  @@unique([userId, skillId])
  @@map("player_skills")
  @@index([userId])
  @@index([characterId])
}

// ─── 던전 시스템 (P5-03) ────────────────────────────────────────
model Dungeon {
  id            String   @id @default(uuid())
  code          String   @unique
  name          String
  description   String   @db.Text
  zoneId        String   @map("zone_id")
  difficulty    String   @default("normal")  // normal, hard, nightmare
  requiredLevel Int      @map("required_level")
  maxPlayers    Int      @default(4) @map("max_players")
  waves         Json     // [{wave, monsters: [{monsterId, count}], isBoss}]
  rewards       Json     // 클리어 보상
  timeLimit     Int      @default(600) @map("time_limit")
  entryCount        Int      @default(3) @map("entry_count")
  isActive          Boolean  @default(true) @map("is_active")
  tags              Json?
  recommendedLevel  Int?     @map("recommended_level")
  dailyRunCount     Int      @default(0) @map("daily_run_count")
  createdAt         DateTime @default(now()) @map("created_at")

  @@map("dungeons")
  @@index([zoneId])
  @@index([difficulty])
}

model DungeonRun {
  id          String    @id @default(uuid())
  dungeonId   String    @map("dungeon_id")
  leaderId    String    @map("leader_id")
  members     Json      // [{userId, damage, deaths}]
  status      String    @default("in_progress")  // in_progress, cleared, failed, abandoned
  currentWave Int       @default(1) @map("current_wave")
  startedAt   DateTime  @default(now()) @map("started_at")
  endedAt     DateTime? @map("ended_at")
  lootResult  Json?     @map("loot_result")
  result      String?
  durationMin Float?    @map("duration_min")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("dungeon_runs")
  @@index([dungeonId])
  @@index([leaderId])
  // P7-14: 상태별 + 기간별 던전 런 조회 (클리어율 집계)
  @@index([status])
  @@index([startedAt])
  @@index([dungeonId, status])
}

// ─── 월드맵/필드 시스템 (P5-04) ─────────────────────────────────
model Zone {
  id            String   @id @default(uuid())
  code          String   @unique
  name          String
  description   String   @db.Text
  region        String   // argentium, silvanhome, erebos, solaris, northland, britallia, oblivion_plateau
  levelRange    Json     @map("level_range")  // {min, max}
  connections   Json     // 인접 존 코드 목록
  npcs          Json     @default("[]")  // 배치된 NPC 목록
  ambientSound  String?  @map("ambient_sound")
  bgm           String?
  mapData       Json?    @map("map_data")  // 타일맵 데이터
  isHub         Boolean  @default(false) @map("is_hub")  // 마을/안전지대
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("zones")
  @@index([region])
}

model PlayerLocation {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  zoneId    String   @map("zone_id")
  posX      Float    @default(0) @map("pos_x")
  posY      Float    @default(0) @map("pos_y")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("player_locations")
}

// ─── 도감/컬렉션 시스템 (P5-08) ─────────────────────────────────
model CodexEntry {
  id              String   @id @default(uuid())
  code            String?  @unique
  title           String?
  userId          String   @default("") @map("user_id")
  category        String   @default("")
  targetCode      String   @default("") @map("target_code")
  discovered      Boolean  @default(true)
  percentage      Float    @default(0)
  content         String?  @db.Text
  unlockCondition String?  @map("unlock_condition")
  unlockedAt      DateTime @default(now()) @map("unlocked_at")

  @@unique([userId, category, targetCode])
  @@map("codex_entries")
  @@index([userId])
  @@index([category])
}

// ─── 알림 시스템 (P5-10) ────────────────────────────────────────
model Notification {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  type        String   // system, achievement, mail, guild, pvp, quest, event, social
  title       String
  message     String
  data        Json?
  isRead      Boolean  @default(false) @map("is_read")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("notifications")
  @@index([userId, isRead])
  @@index([createdAt])
  // P7-14: 타입별 필터 + 읽지 않은 알림 카운트 최적화
  @@index([userId, type])
}

// ─── 거래소/경매장 (P5-06) ──────────────────────────────────────
model AuctionListing {
  id          String   @id @default(uuid())
  sellerId    String   @map("seller_id")
  itemId      String   @map("item_id")
  slotId      String   @map("slot_id")
  quantity    Int      @default(1)
  priceType   String   @default("gold") @map("price_type")
  buyoutPrice Int      @map("buyout_price")
  bidPrice    Int?     @map("bid_price")
  currentBid  Int?     @map("current_bid")
  bidderId    String?  @map("bidder_id")
  status      String   @default("active")  // active, sold, expired, cancelled
  fee         Int      @default(0)  // 등록 수수료
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("auction_listings")
  @@index([sellerId])
  @@index([itemId])
  @@index([status])
  @@index([expiresAt])
}

// ─── 통합 랭킹 (P5-07) ─────────────────────────────────────────
model RankingEntry {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  category    String   // level, combat_power, pvp_rating, raid_clear, achievement_points
  score       Float
  rank        Int?
  season      String?
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([userId, category, season])
  @@map("ranking_entries")
  @@index([category, score])
}

// ─── 결제 영수증 (P6-02) ────────────────────────────────────────
model PaymentReceipt {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  platform      String    // web, ios, android
  productId     String    @map("product_id")
  amount        Int       // 실제 결제금액 (원)
  currency      String    @default("KRW")
  crystalAmount Int       @map("crystal_amount")
  receiptData   String?   @map("receipt_data") @db.Text
  status        String    @default("pending") // pending, verified, failed, refunded
  refundStatus  String?   @map("refund_status")
  verifiedAt    DateTime? @map("verified_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@map("payment_receipts")
  @@index([userId])
  @@index([status])
  // P7-14: 매출 집계 + ARPPU 쿼리 최적화
  @@index([status, createdAt])
  @@index([userId, status])
}

// ─── 코스메틱 아이템 (P6-03) ────────────────────────────────────
model CosmeticItem {
  id            String    @id @default(uuid())
  code          String    @unique
  name          String
  category      String    // skin, weapon_skin, pet_skin, mount, emote, title_effect
  rarity        String    @default("rare") // rare, epic, legendary
  priceType     String    @map("price_type") // crystal, gold, season_reward
  price         Int
  affectsStats  Boolean   @default(false) @map("affects_stats") // P2W 가드: 반드시 false
  preview       String?   // 미리보기 이미지 경로
  description   String?   @db.Text
  isLimited     Boolean   @default(false) @map("is_limited")
  availableFrom DateTime? @map("available_from")
  availableTo   DateTime? @map("available_to")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@map("cosmetic_items")
  @@index([category])
}

// ─── 플레이어 코스메틱 보유/장착 (P6-03) ────────────────────────
model PlayerCosmetic {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  cosmeticId   String   @map("cosmetic_id")
  isEquipped   Boolean  @default(false) @map("is_equipped")
  equippedSlot String?  @map("equipped_slot")
  acquiredAt   DateTime @default(now()) @map("acquired_at")

  @@unique([userId, cosmeticId])
  @@map("player_cosmetics")
  @@index([userId])
}

// ─── 매칭 큐 티켓 (P6-09) ──────────────────────────────────────
model MatchmakingTicket {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  queueType   String    @map("queue_type")   // dungeon, raid, pvp
  contentId   String?   @map("content_id")   // 특정 던전/레이드 ID
  role        String    // tank, dps, healer, any
  level       Int
  gearScore   Int       @map("gear_score")
  status      String    @default("waiting")  // waiting, matched, cancelled, expired
  matchedAt   DateTime? @map("matched_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("matchmaking_tickets")
  @@index([queueType, status])
  @@index([userId])
}

// ─── 챕터 진행도 (P6-10) ───────────────────────────────────────
model ChapterProgress {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  chapter       Int
  status        String    @default("locked")  // locked, unlocked, in_progress, completed
  completedAt   DateTime? @map("completed_at")
  flags         Json      @default("{}")       // 스토리 플래그 (선택지 결과)
  cutscenesSeen Json      @default("[]")       @map("cutscenes_seen")
  createdAt     DateTime  @default(now())      @map("created_at")

  @@unique([userId, chapter])
  @@map("chapter_progress")
  @@index([userId])
}

// ─── 세이브 슬롯 (P6-11) ──────────────────────────────────────
model SaveSlot {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  slot        Int      // 0=auto, 1~3=manual
  label       String?
  data        Json     // 전체 진행 상태 스냅샷
  playtime    Int      @default(0)   // 초
  chapter     Int      @default(1)
  level       Int      @default(1)
  location    String?
  thumbnail   String?  // 스크린샷 base64 (소형)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt     @map("updated_at")

  @@unique([userId, slot])
  @@map("save_slots")
  @@index([userId])
}

// ─── 베타 초대 코드 (P6-19) ───────────────────────────────────
model BetaInvite {
  id          String   @id @default(uuid())
  code        String   @unique
  email       String?
  usedBy      String?  @map("used_by")
  isUsed      Boolean  @default(false) @map("is_used")
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("beta_invites")
  @@index([code])
}

// ─── 피드백 리포트 (P6-19) ────────────────────────────────────
model FeedbackReport {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  type        String   // bug, feature, balance, ux, other
  title       String
  description String   @db.Text
  priority    String   @default("normal") // low, normal, high, critical
  status      String   @default("open") // open, acknowledged, in_progress, resolved, wontfix
  screenshot  String?  @db.Text
  metadata    Json?    // 브라우저/OS/해상도 등
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("feedback_reports")
  @@index([type])
  @@index([status])
}

// ─── 신고 시스템 (P6-12) ──────────────────────────────────────
model Report {
  id          String    @id @default(uuid())
  reporterId  String    @map("reporter_id")
  targetId    String    @map("target_id")
  type        String    // harassment, cheating, botting, inappropriate_name, spam, other
  description String    @db.Text
  evidence    Json?     // 스크린샷 URL, 채팅 로그 등
  status      String    @default("pending") // pending, reviewing, resolved, dismissed
  reviewerId  String?   @map("reviewer_id")
  action      String?   // warn, mute_1h, mute_24h, ban_7d, ban_30d, ban_permanent
  reviewNote  String?   @map("review_note") @db.Text
  resolvedAt  DateTime? @map("resolved_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("reports")
  @@index([targetId])
  @@index([status])
}

// ─── 제재 시스템 (P6-12) ──────────────────────────────────────
model Sanction {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  type       String    // warn, mute, ban
  level      String?   // minor, moderate, severe, critical
  reason     String
  evidence   String?   @db.Text
  duration   Int?      // 분 (null=영구)
  issuedBy   String    @map("issued_by")
  isActive   Boolean   @default(true) @map("is_active")
  expiresAt  DateTime? @map("expires_at")
  appliedBy    String?   @map("applied_by")
  revokedAt    DateTime? @map("revoked_at")
  revokedBy    String?   @map("revoked_by")
  revokeReason String?   @map("revoke_reason")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@map("sanctions")
  @@index([userId])
  @@index([isActive])
  // P7-14: 만료 제재 자동 해제 최적화
  @@index([isActive, expiresAt])
}

// ─── 길드 하우스 (P8-16) ─────────────────────────────────────
model GuildHouse {
  guildId        String   @id @map("guild_id")
  level          Int      @default(1)
  furnitureSlots Int      @default(10) @map("furniture_slots")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  furniture GuildHouseFurniture[]

  @@map("guild_houses")
}

model GuildHouseFurniture {
  id          String   @id @default(uuid())
  guildId     String   @map("guild_id")
  slotIndex   Int      @map("slot_index")
  furnitureId String   @map("furniture_id")
  placedBy    String   @map("placed_by")
  createdAt   DateTime @default(now()) @map("created_at")

  house GuildHouse @relation(fields: [guildId], references: [guildId])

  @@unique([guildId, slotIndex])
  @@map("guild_house_furniture")
  @@index([guildId])
}

// ─── 길드 레이드 (P8-16) ─────────────────────────────────────
model GuildRaid {
  id           String    @id
  guildId      String    @map("guild_id")
  bossId       String    @map("boss_id")
  leaderId     String    @map("leader_id")
  participants String[]
  status       String    // recruiting, in_progress, completed, failed
  scaledBossHp Int?      @map("scaled_boss_hp")
  totalDamage  BigInt?   @map("total_damage")
  durationMs   Int?      @map("duration_ms")
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@map("guild_raids")
  @@index([guildId])
  @@index([guildId, createdAt])
}

// ─── KPI 스냅샷 (P6-14) ──────────────────────────────────────
model KpiSnapshot {
  id        String   @id @default(uuid())
  date      DateTime
  metric    String   // dau, mau, arpu, ltv, retention_d1, retention_d7, retention_d30, revenue, arppu, conversion
  value     Float
  segment   String?  // 세그먼트 (new/returning/whale 등)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([date, metric, segment])
  @@map("kpi_snapshots")
  @@index([metric])
  @@index([date])
}

// ─── 플레이어 하우스 (P8-09) ──────────────────────────────────
model PlayerHouse {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id")
  themeCode   String   @map("theme_code")
  maxSlots    Int      @default(10) @map("max_slots")
  maxVisitors Int      @default(4) @map("max_visitors")
  furniture   Json     @default("[]") // FurniturePlacement[]
  isPublic    Boolean  @default(true) @map("is_public")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("player_houses")
  @@index([isPublic])
}

// ─── 하우스 가구 인벤토리 (P8-09) ─────────────────────────────
model HouseFurniture {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  furnitureId String   @map("furniture_id")
  name        String
  category    String   // table, chair, light, decoration, storage, bed, rug, wall, outdoor, special
  rarity      String   @default("common") // common, uncommon, rare, epic, legendary
  isPlaced    Boolean  @default(false) @map("is_placed")
  acquiredAt  DateTime @default(now()) @map("acquired_at")

  @@map("house_furniture")
  @@index([userId])
  @@index([userId, isPlaced])
}

// ─── 이벤트 참여 기록 (P8-11) ─────────────────────────────────
model EventParticipation {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  eventId     String   @map("event_id")
  score       Int      @default(0)
  rank        Int?
  rewards     Json     @default("[]")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([userId, eventId])
  @@map("event_participations")
  @@index([eventId])
  @@index([eventId, score])
}

// ─── 동의 기록 (P9-12 GDPR) ──────────────────────────────────
model ConsentRecord {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  consentType String    @map("consent_type") // terms, privacy, marketing, analytics
  granted     Boolean   @default(false)
  version     String    // 동의 약관 버전
  grantedAt   DateTime? @map("granted_at")
  revokedAt   DateTime? @map("revoked_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@unique([userId, consentType])
  @@map("consent_records")
  @@index([userId])
  @@index([consentType])
}

// ─── 로그인 세션 (P9-13 계정 보안) ───────────────────────────
model LoginSession {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  deviceName   String   @map("device_name")
  deviceType   String   @map("device_type") // web, mobile, desktop, system
  ipAddress    String   @map("ip_address")
  userAgent    String   @map("user_agent") @db.Text
  accessToken  String?  @map("access_token") @db.Text
  isActive     Boolean  @default(true) @map("is_active")
  lastActiveAt DateTime @default(now()) @map("last_active_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("login_sessions")
  @@index([userId])
  @@index([userId, isActive])
  @@index([isActive])
}

// ─── SNS 공유 (P12-01) ───────────────────────────────────────
model Share {
  id          String   @id                           // shortCode
  userId      String   @map("user_id")
  type        String                                 // achievement | screenshot | character_card | build
  resourceId  String   @map("resource_id")
  message     String?  @db.Text
  imageUrl    String?  @map("image_url")
  ogMeta      Json     @map("og_meta")
  viewCount   Int      @default(0) @map("view_count")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("shares")
  @@index([userId])
  @@index([type])
}

// ─── 레퍼럴 코드 (P12-04) ────────────────────────────────────
model ReferralCode {
  code       String    @id @unique
  ownerId    String    @map("owner_id")
  usedCount  Int       @default(0) @map("used_count")
  maxUses    Int       @default(50) @map("max_uses")
  isActive   Boolean   @default(true) @map("is_active")
  expiresAt  DateTime? @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@map("referral_codes")
  @@index([ownerId])
}

// ─── 레퍼럴 보상 (P12-04) ────────────────────────────────────
model ReferralReward {
  id          String    @id @default(uuid())
  referrerId  String    @map("referrer_id")
  referredId  String    @map("referred_id")
  codeUsed    String    @map("code_used")
  rewardType  String    @map("reward_type")  // diamond | cosmetic_box | premium_pass
  amount      Int
  side        String                          // referrer | referred | milestone
  claimed     Boolean   @default(false)
  claimedAt   DateTime? @map("claimed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("referral_rewards")
  @@index([referrerId])
  @@index([referredId])
  @@index([codeUsed])
}

// ─── UGC 게시글 (P12-05) ─────────────────────────────────────
model UgcPost {
  id          String   @id @default(uuid())
  authorId    String   @map("author_id")
  type        String                          // screenshot | build | guide | fanart
  title       String
  description String?  @db.Text
  imageUrl    String?  @map("image_url")
  buildData   Json?    @map("build_data")
  tags        String[] @default([])
  likeCount   Int      @default(0) @map("like_count")
  viewCount   Int      @default(0) @map("view_count")
  reportCount Int      @default(0) @map("report_count")
  isHidden    Boolean  @default(false) @map("is_hidden")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("ugc_posts")
  @@index([authorId])
  @@index([type])
  @@index([isHidden, createdAt])
  @@index([isHidden, likeCount])
}

// ─── UGC 좋아요 (P12-05) ─────────────────────────────────────
model UgcLike {
  id        String   @id @default(uuid())
  postId    String   @map("post_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([postId, userId])
  @@map("ugc_likes")
  @@index([postId])
  @@index([userId])
}

// ─── 커뮤니티 이벤트 (P12-06) ─────────────────────────────────
model CommunityEvent {
  id               String   @id @default(uuid())
  name             String
  type             String                     // bonus_exp | bonus_drop | special_boss | ...
  description      String   @db.Text
  startAt          DateTime @map("start_at")
  endAt            DateTime @map("end_at")
  config           Json                       // CommunityEventConfig 전체
  status           String   @default("scheduled") // scheduled | active | ended | cancelled
  participantCount Int      @default(0) @map("participant_count")
  createdBy        String   @map("created_by")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("community_events")
  @@index([status])
  @@index([startAt])
  @@index([endAt])
}

// ═══════════════════════════════════════════════════════════════
// P31: 누락 모델 추가 (25개) — tsc 에러 제로화
// ═══════════════════════════════════════════════════════════════

// ─── 거래 시스템 ────────────────────────────────────────────────
model Trade {
  id                 String    @id @default(uuid())
  requesterId        String    @map("requester_id")
  targetId           String    @map("target_id")
  status             String    @default("pending")
  expiresAt          DateTime? @map("expires_at")
  requesterOffer     Json?     @map("requester_offer")
  targetOffer        Json?     @map("target_offer")
  requesterConfirmed Boolean   @default(false) @map("requester_confirmed")
  targetConfirmed    Boolean   @default(false) @map("target_confirmed")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@map("trades")
  @@index([requesterId])
  @@index([targetId])
  @@index([status])
}

// ─── 고객 지원 ──────────────────────────────────────────────────
model SupportTicket {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  category    String
  subject     String
  status      String    @default("open")  // open, in_progress, waiting_user, waiting_admin, resolved, closed
  priority    String    @default("normal")  // low, normal, high, urgent
  assignedTo  String?   @map("assigned_to")
  resolution  String?   @db.Text
  closedAt    DateTime? @map("closed_at")
  closedBy    String?   @map("closed_by")
  resolvedAt  DateTime? @map("resolved_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  messages    TicketMessage[]

  @@map("support_tickets")
  @@index([userId])
  @@index([status])
  @@index([priority])
  @@index([assignedTo])
}

model TicketMessage {
  id          String   @id @default(uuid())
  ticketId    String   @map("ticket_id")
  senderId    String   @map("sender_id")
  senderType  String   @map("sender_type")  // USER, ADMIN, SYSTEM
  content     String   @db.Text
  attachments Json     @default("[]")
  isInternal  Boolean  @default(false) @map("is_internal")
  createdAt   DateTime @default(now()) @map("created_at")

  ticket      SupportTicket @relation(fields: [ticketId], references: [id])
  @@map("ticket_messages")
  @@index([ticketId])
}

// ─── 활동 피드 ──────────────────────────────────────────────────
model ActivityFeedEntry {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  displayName String   @map("display_name")
  eventType   String   @map("event_type")
  visibility  String   @default("FRIENDS")
  payload     Json     @default("{}")
  summary     String   @db.Text
  likeCount   Int      @default(0) @map("like_count")
  createdAt   DateTime @default(now()) @map("created_at")

  likes       FeedLike[]
  @@map("activity_feed_entries")
  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
}

model FeedLike {
  id        String   @id @default(uuid())
  entryId   String   @map("entry_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  entry     ActivityFeedEntry @relation(fields: [entryId], references: [id])
  @@unique([entryId, userId])
  @@map("feed_likes")
  @@index([entryId])
  @@index([userId])
}

// ─── 밸런스 자동 튜닝 ───────────────────────────────────────────
model TuningProposal {
  id            String    @id @default(uuid())
  targetId      String    @map("target_id")
  targetType    String    @map("target_type")  // skill, monster, dungeon
  targetName    String    @map("target_name")
  parameter     String
  currentValue  Float     @map("current_value")
  proposedValue Float     @map("proposed_value")
  changePercent Float     @map("change_percent")
  reason        String    @db.Text
  metrics       Json      @default("{}")
  confidence    Float     @default(0)
  priority      String    @default("normal")
  status        String    @default("pending")  // pending, approved, rejected, applied, reverted
  reviewedAt    DateTime? @map("reviewed_at")
  reviewedBy    String?   @map("reviewed_by")
  rejectReason  String?   @map("reject_reason")
  appliedAt     DateTime? @map("applied_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@map("tuning_proposals")
  @@index([status])
  @@index([targetType])
}

// ─── A/B 테스트 ─────────────────────────────────────────────────
model ABExperiment {
  id                String    @id @default(uuid())
  name              String
  description       String    @db.Text
  featureKey        String    @map("feature_key")
  status            String    @default("draft")  // draft, running, paused, completed, archived
  trafficPercent    Float     @default(1.0) @map("traffic_percent")
  assignmentMethod  String    @default("user_id_hash") @map("assignment_method")
  startDate         DateTime? @map("start_date")
  endDate           DateTime? @map("end_date")
  minSampleSize     Int       @default(500) @map("min_sample_size")
  significanceLevel Float     @default(0.05) @map("significance_level")
  createdBy         String    @map("created_by")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  variants          ABVariant[]
  assignments       ABAssignment[]

  @@map("ab_experiments")
  @@index([featureKey])
  @@index([status])
}

model ABVariant {
  id           String @id @default(uuid())
  experimentId String @map("experiment_id")
  name         String
  description  String @default("")
  weight       Float  @default(0.5)
  config       Json   @default("{}")

  experiment   ABExperiment @relation(fields: [experimentId], references: [id])
  @@map("ab_variants")
  @@index([experimentId])
}

model ABAssignment {
  id           String    @id @default(uuid())
  experimentId String    @map("experiment_id")
  variantId    String    @map("variant_id")
  userId       String    @map("user_id")
  assignedAt   DateTime  @default(now()) @map("assigned_at")
  converted    Boolean   @default(false)
  convertedAt  DateTime? @map("converted_at")
  metricValue  Float?    @map("metric_value")

  experiment   ABExperiment @relation(fields: [experimentId], references: [id])
  @@unique([experimentId, userId])
  @@map("ab_assignments")
  @@index([experimentId])
  @@index([userId])
}

// ─── 파티 멤버 / 초대 ───────────────────────────────────────────
model PartyMember {
  id          String   @id @default(uuid())
  partyId     String   @map("party_id")
  userId      String   @map("user_id")
  role        String   @default("member")  // leader, member
  combatReady Boolean  @default(false) @map("combat_ready")
  joinedAt    DateTime @default(now()) @map("joined_at")

  party       Party    @relation(fields: [partyId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
  @@unique([partyId, userId])
  @@map("party_members")
  @@index([partyId])
  @@index([userId])
}

model PartyInvite {
  id           String    @id @default(uuid())
  partyId      String    @map("party_id")
  inviterId    String    @map("inviter_id")
  targetUserId String    @map("target_user_id")
  status       String    @default("pending")  // pending, accepted, rejected, expired
  expiresAt    DateTime? @map("expires_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  party        Party     @relation(fields: [partyId], references: [id])
  @@map("party_invites")
  @@index([partyId])
  @@index([targetUserId])
}

// ─── 전투 로그 ──────────────────────────────────────────────────
model CombatLog {
  id          String   @id @default(uuid())
  dungeonId   String?  @map("dungeon_id")
  skillId     String?  @map("skill_id")
  playerId    String?  @map("player_id")
  targetId    String?  @map("target_id")
  targetType  String?  @map("target_type")
  result      String?
  damage      Float    @default(0)
  durationMin Float?   @map("duration_min")
  isClear     Boolean  @default(false) @map("is_clear")
  duration    Float?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("combat_logs")
  @@index([skillId])
  @@index([dungeonId])
  @@index([targetId])
  @@index([createdAt])
}

// ─── 스킬 사용 통계 ─────────────────────────────────────────────
model SkillUsageStat {
  id          String   @id @default(uuid())
  skillId     String   @map("skill_id")
  userId      String?  @map("user_id")
  useCount    Int      @default(1) @map("use_count")
  totalDamage Float    @default(0) @map("total_damage")
  winRate     Float?   @map("win_rate")
  playTimeMin Float?   @map("play_time_min")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("skill_usage_stats")
  @@index([skillId])
  @@index([createdAt])
}

// ─── 던전 클리어 기록 ───────────────────────────────────────────
model DungeonClear {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  dungeonId String   @map("dungeon_id")
  clearTime Float?   @map("clear_time")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("dungeon_clears")
  @@index([userId])
  @@index([dungeonId])
}

// ─── 무한 던전 진행 ─────────────────────────────────────────────
model EndlessDungeonProgress {
  id            String   @id @default(uuid())
  playerId      String   @map("player_id")
  weekId        String   @map("week_id")
  highestFloor  Int      @default(0) @map("highest_floor")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([playerId, weekId])
  @@map("endless_dungeon_progress")
  @@index([playerId])
}

// ─── 장비 (초월 시스템) ─────────────────────────────────────────
model Equipment {
  id                  String   @id @default(uuid())
  ownerId             String   @map("owner_id")
  itemId              String?  @map("item_id")
  name                String?
  transcendenceLevel  Int      @default(0) @map("transcendence_level")
  isDestroyed         Boolean  @default(false) @map("is_destroyed")
  stats               Json?
  createdAt           DateTime @default(now()) @map("created_at")

  owner               User     @relation(fields: [ownerId], references: [id])
  @@map("equipment")
  @@index([ownerId])
}

// ─── 초월 로그 ──────────────────────────────────────────────────
model TranscendenceLog {
  id            String   @id @default(uuid())
  playerId      String   @map("player_id")
  equipmentId   String   @map("equipment_id")
  previousLevel Int      @map("previous_level")
  targetLevel   Int      @map("target_level")
  resultLevel   Int      @map("result_level")
  success       Boolean
  destroyed     Boolean  @default(false)
  protected     Boolean  @default(false)
  timestamp     DateTime @default(now())
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("transcendence_logs")
  @@index([playerId])
  @@index([equipmentId])
}

// ─── 게임 세이브 ────────────────────────────────────────────────
model GameSave {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  state     Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("game_saves")
  @@index([userId])
}

// ─── 인벤토리 아이템 (코드 호환용) ──────────────────────────────
model InventoryItem {
  id          String     @id @default(uuid())
  userId      String     @map("user_id")
  characterId String?    @map("character_id")
  itemId      String     @map("item_id")
  itemCode    String?    @map("item_code")
  quantity    Int        @default(1)
  amount      Int        @default(1)
  createdAt   DateTime   @default(now()) @map("created_at")
  character   Character? @relation("CharacterInventory", fields: [characterId], references: [id])

  @@map("inventory_items")
  @@index([userId])
  @@index([itemId])
  @@index([characterId])
  @@index([userId, itemId])
}

// ─── 퀘스트 완료 기록 ───────────────────────────────────────────
model QuestCompletion {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  questId   String   @map("quest_id")
  petId     String?  @map("pet_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("quest_completions")
  @@index([userId])
  @@index([questId])
}

// ─── 스토리 진행 ────────────────────────────────────────────────
model StoryProgress {
  id             String   @id @default(uuid())
  playerId       String   @unique @map("player_id")
  currentChapter Int      @default(1) @map("current_chapter")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("story_progress")
}

// ─── PvP 랭킹 ──────────────────────────────────────────────────
model PvpRanking {
  id     String @id @default(uuid())
  userId String @map("user_id")
  rating Int    @default(1000)
  wins   Int    @default(0)
  losses Int    @default(0)

  @@map("pvp_rankings")
  @@index([userId])
  @@index([rating])
}

// ─── PvP 시즌 보상 ──────────────────────────────────────────────
model PvpSeasonReward {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  season    Int
  tier      String
  rating    Int
  rewards   Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("pvp_season_rewards")
  @@index([userId])
  @@index([season])
}

// ─── 유저 업적 (코드 호환용) ────────────────────────────────────
model UserAchievement {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  achievementId String    @map("achievement_id")
  unlockedAt    DateTime? @map("unlocked_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  achievement   Achievement @relation(fields: [achievementId], references: [id])
  @@map("user_achievements")
  @@index([userId])
  @@index([achievementId])
}

// ─── 유저 행동 기록 (추천 엔진) ─────────────────────────────────
model UserAction {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  targetType String   @map("target_type")
  targetId   String   @map("target_id")
  actionType String   @map("action_type")
  rating     Float?
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("user_actions")
  @@index([userId])
  @@index([targetType])
  @@index([createdAt])
}

// ─── 펫 진화 히스토리 ───────────────────────────────────────────
model PetEvolutionHistory {
  id                String   @id @default(uuid())
  petId             String   @map("pet_id")
  userId            String   @map("user_id")
  petFamily         String   @map("pet_family")
  fromStage         String   @map("from_stage")
  toStage           String   @map("to_stage")
  materialsConsumed Json     @default("[]") @map("materials_consumed")
  statsBefore       Json     @default("{}") @map("stats_before")
  statsAfter        Json     @default("{}") @map("stats_after")
  createdAt         DateTime @default(now()) @map("created_at")

  @@map("pet_evolution_history")
  @@index([petId])
  @@index([userId])
}

// ─── 플레이어 (월드보스 참가자 조회용) ──────────────────────────
model Player {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  nickname  String?
  level     Int      @default(1)
  classId   String?  @map("class_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("players")
  @@index([userId])
}

model CharacterSkill {
  id          String   @id @default(uuid())
  characterId String   @map("character_id")
  skillId     String   @map("skill_id")
  skillCode   String?  @map("skill_code")
  level       Int      @default(1)
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([characterId, skillId])
  @@map("character_skills")
  @@index([characterId])
}

// ─── 가구 시스템 (P8-10) ────────────────────────────────────────
model Furniture {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  category    String   // table, chair, light, decoration, storage, bed, rug, wall, outdoor, special
  rarity      String   @default("common")
  description String?  @db.Text
  effect      Json?    // {type, value}
  recipe      Json?    // {materials, requiredLevel, craftTime, successRate}
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("furnitures")
  @@index([category])
}

// ─── PvP 맵 (P8-15) ────────────────────────────────────────────
model PvpMap {
  id                 String   @id @default(uuid())
  code               String   @unique
  name               String
  nameEn             String?  @map("name_en")
  nameJa             String?  @map("name_ja")
  season             Int      @default(1)
  description        String?  @db.Text
  width              Int      @default(20)
  height             Int      @default(20)
  environmentEffects Json?    @map("environment_effects")
  terrainFeatures    Json?    @map("terrain_features")
  spawnPoints        Json?    @map("spawn_points")
  minRating          Int      @default(0) @map("min_rating")
  unlockCondition    String?  @map("unlock_condition")
  createdAt          DateTime @default(now()) @map("created_at")

  @@map("pvp_maps")
  @@index([season])
}

// ─── 월드 보스 (P11-05) ─────────────────────────────────────────
model WorldBoss {
  id             String   @id @default(uuid())
  code           String   @unique
  name           String
  description    String?  @db.Text
  maxHp          Int      @map("max_hp")
  attack         Int      @default(0)
  defense        Int      @default(0)
  skills         Json?
  phases         Json?
  lootTable      Json?    @map("loot_table")
  requiredLevel  Int      @default(1) @map("required_level")
  weeklySchedule Int      @default(0) @map("weekly_schedule")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("world_bosses")
}

// ─── 대화/스토리 노드 (P8-12) ───────────────────────────────────
model Dialogue {
  id        String   @id @default(uuid())
  code      String   @unique
  chapter   Int      @default(0)
  scene     String?
  speaker   String
  text      String   @db.Text
  portrait  String?
  voiceKey  String?  @map("voice_key")
  order     Int      @default(0)
  nextCode  String?  @map("next_code")
  choices   Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("dialogues")
  @@index([chapter, scene])
}
