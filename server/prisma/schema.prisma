generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String      @id @default(uuid())
  email     String      @unique
  password  String      // 실제로는 bcrypt 등으로 해싱하여 저장
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  characters Character[]
}

model Character {
  id        String   @id @default(uuid())
  userId    String
  name      String   @unique
  classId   String   // 직업 ID (예: Warrior, Mage 등)
  level     Int      @default(1)
  exp       Int      @default(0)
  hp        Int      @default(200)
  mp        Int      @default(100)
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Phase 1 인벤토리/장비 데이터는 DB 구조 단순화를 위해 JSONB로 관리 (확장성 고려)
  inventoryData Json?

  @@index([userId])
}

// ─── 텔레메트리: 대화 선택지 이벤트 ───────────────────────────
model TelemetryDialogueChoice {
  id              String   @id @default(uuid())
  eventId         String   @map("event_id")
  eventTs         DateTime @map("event_ts")
  sessionId       String   @map("session_id")
  playerIdHash    String   @map("player_id_hash")
  chapterId       String   @map("chapter_id")
  sceneId         String   @map("scene_id")
  npcId           String   @map("npc_id")
  dialogueNodeId  String   @map("dialogue_node_id")
  choiceId        String   @map("choice_id")
  choiceTextKey   String   @map("choice_text_key")
  inputMode       String   @map("input_mode")
  latencyMs       Int?     @map("latency_ms")
  partyComp       Json?    @map("party_comp")
  difficultyTier  String?  @map("difficulty_tier")
  buildVersion    String   @map("build_version")
  platform        String
  region          String?
  idempotencyKey  String   @unique @map("idempotency_key")
  deduped         Boolean  @default(false)
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("telemetry_dialogue_choice_events")
  @@index([chapterId, sceneId, npcId])
  @@index([sessionId])
  @@index([eventTs])
  @@index([playerIdHash])
}

// ─── 텔레메트리: 범용 게임 이벤트 (향후 확장용) ─────────────────
model TelemetryGameEvent {
  id          String   @id @default(uuid())
  eventType   String   @map("event_type")
  eventTs     DateTime @map("event_ts")
  sessionId   String   @map("session_id")
  playerId    String   @map("player_id")
  payload     Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("telemetry_game_events")
  @@index([eventType, eventTs])
  @@index([sessionId])
  @@index([playerId])
}

// ─── 길드 시스템 ────────────────────────────────────────────────
model Guild {
  id          String   @id @default(uuid())
  name        String   @unique
  tag         String   @unique @db.VarChar(5)  // 길드 태그 (2~5자)
  leaderId    String   @map("leader_id")
  level       Int      @default(1)
  exp         Int      @default(0)
  maxMembers  Int      @default(30) @map("max_members")
  notice      String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  members      GuildMember[]
  wars         GuildWar[]     @relation("AttackerGuild")
  warsAsTarget GuildWar[]     @relation("DefenderGuild")

  @@map("guilds")
}

model GuildMember {
  id       String   @id @default(uuid())
  guildId  String   @map("guild_id")
  userId   String   @map("user_id")
  role     String   @default("member")  // leader, officer, member
  joinedAt DateTime @default(now()) @map("joined_at")

  guild    Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, userId])
  @@map("guild_members")
}

model GuildWar {
  id            String    @id @default(uuid())
  attackerId    String    @map("attacker_id")
  defenderId    String    @map("defender_id")
  status        String    @default("pending")  // pending, active, finished
  attackerScore Int       @default(0) @map("attacker_score")
  defenderScore Int       @default(0) @map("defender_score")
  startedAt     DateTime? @map("started_at")
  endedAt       DateTime? @map("ended_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  attacker      Guild     @relation("AttackerGuild", fields: [attackerId], references: [id])
  defender      Guild     @relation("DefenderGuild", fields: [defenderId], references: [id])

  @@map("guild_wars")
}

// ─── PvP 아레나 시스템 ──────────────────────────────────────
model PvpMatch {
  id            String    @id @default(uuid())
  player1Id     String    @map("player1_id")
  player2Id     String    @map("player2_id")
  winnerId      String?   @map("winner_id")
  player1Score  Int       @default(0) @map("player1_score")
  player2Score  Int       @default(0) @map("player2_score")
  arenaType     String    @default("ranked") @map("arena_type")  // ranked, casual, tournament
  season        Int       @default(1)
  duration      Int?      // 매치 소요 시간 (초)
  status        String    @default("matching")  // matching, ready, fighting, finished
  startedAt     DateTime? @map("started_at")
  endedAt       DateTime? @map("ended_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@map("pvp_matches")
  @@index([player1Id])
  @@index([player2Id])
  @@index([season, arenaType])
}

model PvpRating {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  season     Int      @default(1)
  rating     Int      @default(1000)
  tier       String   @default("bronze")  // bronze, silver, gold, platinum, diamond, master
  wins       Int      @default(0)
  losses     Int      @default(0)
  streak     Int      @default(0)
  peakRating Int      @default(1000) @map("peak_rating")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([userId, season])
  @@map("pvp_ratings")
  @@index([season, rating(sort: Desc)])
}

// ─── 엔딩 시스템: 엔딩 달성 기록 ────────────────────────────
model EndingRecord {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  endingType  String   @map("ending_type")
  flags       Json     // 판정 시점 플래그 스냅샷
  playthrough Int      @default(1)
  achievedAt  DateTime @default(now()) @map("achieved_at")

  @@map("ending_records")
  @@index([userId])
  @@index([endingType])
}

// ─── 상점 시스템 ────────────────────────────────────────────────
model ShopItem {
  id          String    @id @default(uuid())
  name        String
  category    String    // cosmetic, convenience, season_pass, bundle
  price       Int       // 프리미엄 화폐 가격
  currency    String    @default("crystal")  // crystal(유료), gold(무료)
  rarity      String    @default("common")   // common, rare, epic, legendary
  description String?   @db.Text
  imageUrl    String?   @map("image_url")
  isActive    Boolean   @default(true) @map("is_active")
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date")
  createdAt   DateTime  @default(now()) @map("created_at")

  purchases   Purchase[]
  @@map("shop_items")
  @@index([category, isActive])
}

model Purchase {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  itemId    String   @map("item_id")
  price     Int
  currency  String
  createdAt DateTime @default(now()) @map("created_at")

  item      ShopItem @relation(fields: [itemId], references: [id])
  @@map("purchases")
  @@index([userId])
}

// ─── 시즌 패스 시스템 ───────────────────────────────────────────
model SeasonPass {
  id             String   @id @default(uuid())
  season         Int      @unique
  name           String
  startDate      DateTime @map("start_date")
  endDate        DateTime @map("end_date")
  freeRewards    Json     @map("free_rewards")    // [{level, reward}]
  premiumRewards Json     @map("premium_rewards")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")

  progresses     SeasonPassProgress[]
  @@map("season_passes")
}

model SeasonPassProgress {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  seasonPassId   String   @map("season_pass_id")
  level          Int      @default(0)
  exp            Int      @default(0)
  isPremium      Boolean  @default(false) @map("is_premium")
  claimedFree    Json     @default("[]") @map("claimed_free")
  claimedPremium Json     @default("[]") @map("claimed_premium")
  updatedAt      DateTime @updatedAt @map("updated_at")

  seasonPass     SeasonPass @relation(fields: [seasonPassId], references: [id])
  @@unique([userId, seasonPassId])
  @@map("season_pass_progress")
}

// ─── 업적 시스템 ────────────────────────────────────────────────
model Achievement {
  id          String   @id @default(uuid())
  code        String   @unique  // "FIRST_BLOOD", "GUILD_MASTER" 등
  name        String
  description String   @db.Text
  category    String   // combat, exploration, social, collection, story
  tier        String   @default("bronze")  // bronze, silver, gold, platinum
  icon        String?
  points      Int      @default(10)
  isHidden    Boolean  @default(false) @map("is_hidden")
  condition   Json     // 달성 조건 정의 {type, target, count}
  createdAt   DateTime @default(now()) @map("created_at")

  unlocks     AchievementUnlock[]
  @@map("achievements")
  @@index([category])
}

model AchievementUnlock {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  achievementId String   @map("achievement_id")
  unlockedAt    DateTime @default(now()) @map("unlocked_at")

  achievement   Achievement @relation(fields: [achievementId], references: [id])
  @@unique([userId, achievementId])
  @@map("achievement_unlocks")
  @@index([userId])
}

model Title {
  id            String   @id @default(uuid())
  name          String   @unique
  description   String?
  rarity        String   @default("common")
  achievementId String?  @map("achievement_id")  // 연동 업적
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("titles")
}

// ─── 레이드 보스 시스템 ─────────────────────────────────────────
model RaidBoss {
  id          String   @id @default(uuid())
  name        String
  tier        String   // normal, heroic, mythic
  maxHp       Int      @map("max_hp")
  attack      Int
  defense     Int
  mechanics   Json?    // 보스 패턴/기믹 정의
  lootTable   Json     @map("loot_table")  // [{itemId, dropRate, tier}]
  minPlayers  Int      @default(4) @map("min_players")
  maxPlayers  Int      @default(10) @map("max_players")
  timeLimit   Int      @default(600) @map("time_limit")  // 초
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  sessions    RaidSession[]
  @@map("raid_bosses")
}

model RaidSession {
  id           String    @id @default(uuid())
  bossId       String    @map("boss_id")
  guildId      String?   @map("guild_id")
  status       String    @default("forming")  // forming, fighting, cleared, failed
  currentHp    Int       @map("current_hp")
  participants Json      // [{userId, damage, role}]
  startedAt    DateTime? @map("started_at")
  endedAt      DateTime? @map("ended_at")
  lootResult   Json?     @map("loot_result")
  createdAt    DateTime  @default(now()) @map("created_at")

  boss         RaidBoss  @relation(fields: [bossId], references: [id])
  @@map("raid_sessions")
  @@index([bossId])
  @@index([guildId])
  @@index([status])
}

// ─── 2차 전직 시스템 ────────────────────────────────────────────
model ClassAdvancement {
  id            String   @id @default(uuid())
  baseClass     String   @map("base_class")      // ether_knight, memory_weaver, shadow_weaver
  advancedClass String   @map("advanced_class")
  tier          Int                                // 1(Lv.30), 2(Lv.50), 3(Lv.80)
  requiredLevel Int      @map("required_level")
  questId       String?  @map("quest_id")
  skills        Json                               // 해금 스킬 목록
  statBonus     Json     @map("stat_bonus")
  ultimateSkill Json?    @map("ultimate_skill")    // tier 3만
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("class_advancements")
  @@unique([baseClass, tier])
}

// ─── 제작 시스템 ────────────────────────────────────────────────
model Recipe {
  id            String   @id @default(uuid())
  name          String   @unique
  description   String   @db.Text
  category      String   // weapon, armor, accessory, consumable, material
  resultItemId  String   @map("result_item_id")
  resultCount   Int      @default(1) @map("result_count")
  materials     Json     // [{itemId, name, count}]
  requiredLevel Int      @default(1) @map("required_level")
  craftTime     Int      @default(5) @map("craft_time")  // 초
  successRate   Float    @default(1.0) @map("success_rate")  // 0.0~1.0
  isUnlocked    Boolean  @default(true) @map("is_unlocked")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("recipes")
  @@index([category])
}

model CraftLog {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  recipeId    String   @map("recipe_id")
  success     Boolean
  resultItem  String?  @map("result_item")
  craftedAt   DateTime @default(now()) @map("crafted_at")

  @@map("craft_logs")
  @@index([userId])
}

// ─── 펫 시스템 ──────────────────────────────────────────────────
model Pet {
  id          String   @id @default(uuid())
  ownerId     String   @map("owner_id")
  name        String
  species     String   // wolf, phoenix, golem, fairy, dragon 등
  grade       String   @default("common")  // common, rare, epic, legendary
  level       Int      @default(1)
  exp         Int      @default(0)
  maxExp      Int      @default(100) @map("max_exp")
  hp          Int      @default(100)
  attack      Int      @default(10)
  defense     Int      @default(5)
  skills      Json     @default("[]")  // [{skillId, name, damage, cooldown, level}]
  bond        Int      @default(0)     // 유대감 (0~100)
  isActive    Boolean  @default(false) @map("is_active")  // 현재 소환 중
  obtainedAt  DateTime @default(now()) @map("obtained_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("pets")
  @@index([ownerId])
  @@index([species])
}

model PetSkill {
  id          String   @id @default(uuid())
  name        String   @unique
  description String   @db.Text
  damage      Int      @default(0)
  cooldown    Int      @default(10)  // 초
  effectType  String   @map("effect_type")  // damage, heal, buff, debuff
  targetType  String   @default("single") @map("target_type")  // single, aoe
  unlockLevel Int      @default(1) @map("unlock_level")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("pet_skills")
}

// ─── NPC 시스템 ─────────────────────────────────────────────────
model Npc {
  id           String   @id @default(uuid())
  name         String   @unique
  title        String?
  role         String   // merchant, quest_giver, trainer, villager, guard, boss
  location     String   // 지역 ID
  dialogue     Json     // 대화 트리 [{id, text, options: [{text, nextId, condition?}]}]
  schedule     Json?    // 시간대별 위치/행동 [{hour, location, action}]
  behaviorTree Json     @map("behavior_tree")  // 행동 트리 정의
  stats        Json?    // 전투 NPC용 스탯
  shopItems    Json?    @map("shop_items")  // 상점 NPC용 판매 목록
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("npcs")
  @@index([role])
  @@index([location])
}

model NpcAffinity {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  npcId     String   @map("npc_id")
  level     Int      @default(0)  // 0~10
  exp       Int      @default(0)
  gifts     Json     @default("[]")  // 선물 이력
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, npcId])
  @@map("npc_affinities")
}
