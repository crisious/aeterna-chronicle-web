{
  "name": "aeterna-chronicle",
  "version": "1.0.0-rc.2",
  "description": "에테르나 크로니클 — FF6 스타일 ATB 전투 RPG (Phaser.js)",
  "private": true,
  "workspaces": [
    "server",
    "client",
    "admin-dashboard"
  ],
  "scripts": {
    "install:all": "npm install",
    "prisma:generate": "npm --prefix server run prisma:generate",
    "bootstrap": "npm install && npm run prisma:generate",
    "install:test": "npm run bootstrap && npm run typecheck && npm run test",
    "lint:server": "eslint \"server/src/**/*.ts\"",
    "lint:client": "eslint \"client/src/**/*.{ts,tsx}\"",
    "lint:admin": "eslint \"admin-dashboard/src/**/*.{ts,tsx}\"",
    "lint:shared": "eslint \".eslintrc.js\" \"shared/**/*.ts\" \"tests/**/*.ts\"",
    "lint": "npm run lint:server && npm run lint:client && npm run lint:admin && npm run lint:shared",
    "typecheck:server": "npm --prefix server run typecheck",
    "typecheck:client": "npm --prefix client run typecheck",
    "typecheck:admin": "npm --prefix admin-dashboard run typecheck",
    "typecheck": "npm run typecheck:server && npm run typecheck:client && npm run typecheck:admin",
    "build:server": "npm --prefix server run build",
    "build:client": "npm --prefix client run build",
    "build:admin": "npm --prefix admin-dashboard run build",
    "build": "npm run build:server && npm run build:client && npm run build:admin",
    "test:unit": "vitest run --config tests/vitest.config.ts tests/unit/",
    "test:contract": "vitest run --config tests/vitest.config.ts tests/contract/ admin-dashboard/src/__tests__/",
    "test:integration": "vitest run --config tests/vitest.config.ts tests/integration/",
    "test:e2e": "vitest run --config tests/vitest.config.ts tests/e2e/",
    "test:all": "vitest run --config tests/vitest.config.ts",
    "test": "npm run test:unit && npm run test:contract",
    "test:watch": "vitest --config tests/vitest.config.ts",
    "test:coverage": "vitest run --config tests/vitest.config.ts --coverage",
    "test:a11y:unit": "vitest run --config tests/vitest.config.ts tests/unit/a11y",
    "a11y:audit": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types ./scripts/a11y/audit.ts",
    "mp:catalog": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types ./scripts/monster-pipeline/cli.ts catalog",
    "mp:generate": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types ./scripts/monster-pipeline/cli.ts generate",
    "mp:touchup": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types ./scripts/monster-pipeline/cli.ts touchup",
    "mp:gate": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types ./scripts/monster-pipeline/cli.ts gate",
    "mp:all": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types ./scripts/monster-pipeline/cli.ts all",
    "monsters:catalog": "npm run mp:catalog --",
    "monsters:generate": "npm run mp:generate --",
    "monsters:touchup": "npm run mp:touchup --",
    "monsters:gate": "npm run mp:gate --",
    "monsters:all": "npm run mp:all --",
    "seed": "npm --prefix server run seed",
    "seed:dry": "npm --prefix server run seed:dry",
    "seed:check": "npm --prefix server run seed:check",
    "seed:reset": "npx prisma db push --force-reset && npm run seed",
    "seed:staging": "npm --prefix server run seed:staging",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run build",
    "dev:measure": "node scripts/dev-cycle/measure-boot.mjs",
    "dev:verify": "node scripts/dev-cycle/verify-core.mjs",
    "dev:fmt-error": "node scripts/dev-cycle/format-error.mjs",
    "dev:typecheck": "npm run typecheck:client 2>&1 | node scripts/dev-cycle/format-error.mjs --gate=type",
    "dev:build": "npm run build:client 2>&1 | node scripts/dev-cycle/format-error.mjs --gate=build"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@typescript-eslint/eslint-plugin": "^8.29.1",
    "@typescript-eslint/parser": "^8.29.1",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.4",
    "fastify": "^5.8.2",
    "jsonwebtoken": "^9.0.3",
    "vitest": "^3.0.0"
  }
}
