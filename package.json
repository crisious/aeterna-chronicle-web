{
  "name": "aeterna-chronicle",
  "version": "0.5.14",
  "description": "에테르나 크로니클 — MMORPG 프로젝트",
  "private": true,
  "workspaces": [
    "server",
    "client",
    "admin-dashboard"
  ],
  "scripts": {
    "install:all": "npm install",
    "prisma:generate": "npm --prefix server run prisma:generate",
    "bootstrap": "npm install && npm run prisma:generate",
    "install:test": "npm run bootstrap && npm run typecheck && npm run test",
    "lint:server": "eslint \"server/src/**/*.ts\"",
    "lint:client": "eslint \"client/src/**/*.{ts,tsx}\"",
    "lint:admin": "eslint \"admin-dashboard/src/**/*.{ts,tsx}\"",
    "lint:shared": "eslint \".eslintrc.js\" \"shared/**/*.ts\" \"tests/**/*.ts\"",
    "lint": "npm run lint:server && npm run lint:client && npm run lint:admin && npm run lint:shared",
    "typecheck:server": "npm --prefix server run typecheck",
    "typecheck:client": "npm --prefix client run typecheck",
    "typecheck:admin": "npm --prefix admin-dashboard run typecheck",
    "typecheck": "npm run typecheck:server && npm run typecheck:client && npm run typecheck:admin",
    "build:server": "npm --prefix server run build",
    "build:client": "npm --prefix client run build",
    "build:admin": "npm --prefix admin-dashboard run build",
    "build": "npm run build:server && npm run build:client && npm run build:admin",
    "test:unit": "vitest run --config vitest.config.ts --include 'tests/unit/**/*.test.ts'",
    "test:contract": "vitest run --config vitest.config.ts --include 'tests/contract/**/*.test.ts' --include 'admin-dashboard/src/__tests__/**/*.test.{ts,tsx}'",
    "test:integration": "vitest run --config vitest.config.ts --include 'tests/integration/**/*.test.ts'",
    "test:e2e": "vitest run --config vitest.config.ts --include 'tests/e2e/**/*.test.ts'",
    "test:all": "vitest run --config vitest.config.ts",
    "test": "npm run test:unit && npm run test:contract",
    "test:watch": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "seed": "npm --prefix server run seed",
    "seed:dry": "npm --prefix server run seed:dry",
    "seed:check": "npm --prefix server run seed:check",
    "seed:reset": "npx prisma db push --force-reset && npm run seed",
    "seed:staging": "npm --prefix server run seed:staging",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.29.1",
    "@typescript-eslint/parser": "^8.29.1",
    "vitest": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.4"
  }
}
